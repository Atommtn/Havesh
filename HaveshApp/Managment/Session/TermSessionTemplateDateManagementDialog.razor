@using ShokouhApp.Admin.Components
@using ShokouhApp.Model
@using DNTPersianUtils.Core
@using Olive
<MtnDialog>
    <ChildComponent>
        <MudTable Items="_dates">
            <ToolBarContent>
                <MudButton Variant="Variant.Text" Color="Color.Success" StartIcon="@Icons.TwoTone.Add" OnClick="NewDateClick">
                    Add New Date
                </MudButton>

            </ToolBarContent>
            <HeaderContent>
                <MudTh>جلسه</MudTh>
                <MudTh>تاریخ</MudTh>
                <MudTh>توضیح</MudTh>
                <MudTh>

                </MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.SessionNumber</MudTd>
                <MudTd>@context.Date.ToPersianDateTextify()</MudTd>
                <MudTd>@context.Description</MudTd>
                <MudTd>
                    @if (_dates.LastOrDefault() == context)
                    {
                        <MudIconButton Icon="@Icons.TwoTone.Delete" Color="Color.Error" OnClick="() => DeleteSessionClick(context)"></MudIconButton>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </ChildComponent>
    <DialogAction>

    </DialogAction>
</MtnDialog>

@code {
    [Parameter]
    public TermSessionTemplate TermSessionTemplate { get; set; }

    public List<TermSessionTemplate> TermSessionTemplateDates { get; set; } = new();

    protected override void OnInitialized()
    {
        _weekDays = _dataProvider.GetWeekDays();
        UpdateDates();
        base.OnInitialized();
    }

    void UpdateDates()
    {
        _dates = _dataProvider.GetTermSessionTemplateDates(TermSessionTemplate);
    }

    List<TermSessionTemplateDate> _dates;
    List<ShokouhPardisWeekDay> _weekDays;

    [Inject]
    public IDialogService DialogService { get; set; }

    async Task NewDateClick()
    {
        var lastItem = _dates.LastOrDefault();
        var dt = (DateTime)TermSessionTemplate.Term.StartDate;
        if (lastItem != null)
        {
            dt = (DateTime)lastItem.Date;

            var dayOfWeek = ((int)lastItem.Date?.GetPersianWeekDayNumber())!;
            var strings = TermSessionTemplate.WeekdayIds.Split(',').Select(x => Convert.ToInt32(x)).ToArray();

            var nextItem = strings[(strings.IndexOf(dayOfWeek) + 1) % strings.Length];
            var add = 0;
            if (nextItem <= dayOfWeek)
                add = 7 - dayOfWeek + nextItem;
            else
                add = nextItem - dayOfWeek;
            dt = dt.AddDays(add);
            /*
                if (dt.IsHoliday())
                {

                }
            */
        }
        var date = new TermSessionTemplateDate()
            {
                SessionNumber = _dates.Count + 1,
                TermSessionTemplate = TermSessionTemplate,
                Date = dt
            };
        var dref = await DialogService.ShowAsync<TermSessionTemplateDateDialog>("Date", new DialogParameters()
            {
                ["TermSessionTemplateDate"] = date
            },
            new DialogOptions()
                {
                    MaxWidth = MaxWidth.Medium,
                    FullWidth = true
                });
        var dialogResult = await dref.Result;
        if (!dialogResult.Canceled)
        {
            UpdateDates();
        }

    }

    async Task DeleteSessionClick(TermSessionTemplateDate context)
    {
        var msg = await _dialogService.ShowMessageBox("Warning", "Are you sure you want delete this Session Template Date ?",
            "Yes", "No");
        if (msg is true)
        {
            _dataProvider.DeleteTermSessionTemplateDate(context);
            _snackBar.Add("Template Session Date Deleted");
            UpdateDates();
        }
    }

}
