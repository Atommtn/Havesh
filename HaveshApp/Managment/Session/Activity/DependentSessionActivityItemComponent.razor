@using System.Collections
@using Havesh.Model.Model
@using Newtonsoft.Json
@using Newtonsoft.Json.Linq

<MudPaper Elevation="1" Outlined="true">
    @switch (SessionActivity.ValueControl)
    {
        case "Buttons":
            foreach (var btn in 
	            SessionActivity.ValueOptions.Where(x => 
		            x.ShowByValue == StudentSessionActivity.ActivityValue &&
					!AllStudentSessionActivities.Any(z => z.ActivityValue == x.Value && z.ActivityDeletedDateTime == null)))
            {

                <MudButton Class="mr-2" Color="@GetButtonColor(btn)" Variant="Variant.Filled" OnClick="()=>BtnClick(btn)">
                    @btn.Title
                </MudButton>
            }
            break;
    }
</MudPaper>

@code {
    [Parameter]
    public EventCallback<(ShokouhPardisStudentClass, SessionActivity, SessionActivityValueOption)> ActivityExec { get; set; }

    [Parameter]
    public SessionActivity SessionActivity { get; set; }

    [Parameter]
    public IEnumerable<StudentSessionActivity> AllStudentSessionActivities { get; set; }

    [Parameter]
    public StudentSessionActivity StudentSessionActivity { get; set; }

    [Parameter]
    public ShokouhPardisStudentClass Student { get; set; }

    private async Task BtnClick(SessionActivityValueOption sao)
    {
        await ActivityExec.InvokeAsync((Student, SessionActivity, sao));
    }

    private Color GetButtonColor(SessionActivityValueOption sao)
    {
        if (sao.Color == null)
            return Color.Default;

        return sao.Color.ToLower() switch
        {
            "green" => Color.Success,
            "yellow" => Color.Warning,
            "red" => Color.Error,
            "blue" => Color.Primary,
            _ => Color.Default
        };
    }

}
