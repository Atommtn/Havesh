@using Havesh.Model.Model
<MtnDialog>
    <ChildComponent>
        <MudGrid>
            <MudItem md="6">
                <MudTextField @bind-Value="ValueOption.Title" Label="Title"/>
            </MudItem>
            <MudItem md="6">
                <MudTextField @bind-Value="ValueOption.Color" Label="Color" />
            </MudItem>
	        <MudItem md="6">
		        <IconSelectorComponent @bind-Icon="ValueOption.Icon" @bind-IconName="ValueOption.IconName"></IconSelectorComponent>
	        </MudItem>
            <MudItem md="6">
                <MudTextField @bind-Value="ValueOption.Value" Label="Value" />
            </MudItem>
            <MudItem md="6">
                <MudTextField @bind-Value="ValueOption.ShowByValue" Label="Show After Value Is" />
            </MudItem>
        </MudGrid>

    </ChildComponent>
    <DialogAction>
        <MudButton Color="Color.Success" StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" OnClick="SaveValueOptionClick">
            Save
        </MudButton>

        <MudButton Color="Color.Warning" StartIcon="@Icons.Material.Filled.Close" Variant="Variant.Text" OnClick="CloseClick">
            Close
        </MudButton>

    </DialogAction>
</MtnDialog>

@code {

    [Parameter]
    public SessionActivityValueOption ValueOption { get; set; }

    [CascadingParameter]
    public MudDialogInstance DialogInstance { get; set; }


    private void SaveValueOptionClick()
    {
        _dataProvider.SaveValueOption(ValueOption);
        _snackBar.Add("Value Option Saved Successfully");
        DialogInstance.Close();
    }

    private void CloseClick()
    {
        DialogInstance.Cancel();
    }

}
