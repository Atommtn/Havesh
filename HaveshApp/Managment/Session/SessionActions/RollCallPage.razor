@page "/RollCall/{SessionId:int}/{SessionActivityId:int}"
@using DNTPersianUtils.Core
@using Havesh.Model.Model
@using Microsoft.EntityFrameworkCore
@using PersianDate.Standard
@layout PersianPagesLayout

<StudentListRollCallComponenets 
    RowStyle="true" 
    RowsPerPage="25" 
    TimeTableSession="SessionItem" 
    SessionActivity="SessionActivity" />

@code {
    private int _sessionId;
    private int _sessionActivityId;
	
	public TimeTableSession? SessionItem { get; private set; }
	public SessionActivity? SessionActivity { get; private set; }

	[Parameter]
    public int SessionId
    {
        get => _sessionId;
        set
        {
            _sessionId = value;
            SessionItem = _dataProvider.GetTimeTableSessionById(_sessionId , 
	            q=>
	            q.Include(x => x.TimeTable)
	             .ThenInclude(x => x.Level));
        }
    }

    [Parameter]
    public int SessionActivityId
    {
        get => _sessionActivityId;
        set
        {
            _sessionActivityId = value;
            SessionActivity = _dataProvider.GetSessionActivity(_sessionActivityId);
        }
    }
}
