@page "/SupervisorClassAction/{SessionId:int}"
@using Havesh.Model.Model

@if (_session?.TimeTable != null)
{
   
   <TimeTableItemComponent TimeTable="_session.TimeTable" Dense="false" ShowRecordId="false" ShowSessionCount="false" IsSessionCanceler="false">
      
    </TimeTableItemComponent>
}
@foreach (var act in _activities)
{
    <MudButton Color="Color.Success" StartIcon="@Icons.Material.Filled.Class" Variant="Variant.Outlined" OnClick="() => ClassSessionClick(_session,act)">
        <MudText Typo="Typo.caption" Color="Color.Default" GutterBottom="true">
            @act.ActivityTitle - جلسه @_session?.SessionNumber
        </MudText>
    </MudButton>

}

@code {

    ShokouhPardisTimeTable? TimeTableItem { get; set; }
    [Parameter]
    public int SessionId
    {
        get => _sessionId;
        set
        {
            _sessionId = value;
            //TimeTableItem = _dataProvider.GetTimeTable(_timeTableId);
            _session = _dataProvider.GetSession(_sessionId);
            if (_session != null)
                _activities = _dataProvider.GetSessionActivities(_session);
        }
    }

    private int _sessionId;
    private TimeTableSession _session;
    private List<SessionActivity> _activities;

    private void ClassSessionClick(TimeTableSession session, SessionActivity sessionActivity)
    {
        _navigationManager.NavigateTo($"/RollCall/{session?.Id}/{sessionActivity.Id}");
    }
}
