@page "/ClassProgram/{*Options}"

@layout PersianPagesLayout

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="desktop-fixed-table">
    <MudGrid>
        <MudItem xs="12">
            <TermSelectorComponent @bind-Term="SelectedTerm"></TermSelectorComponent>
        </MudItem>
        <MudItem sm="12" md="6">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.Center">
                <MudText Typo="Typo.body1">روزهای زوج</MudText>
                <MudSwitch @bind-Checked="OddEvenSwitch"></MudSwitch>
                <MudText Typo="Typo.body1">روزهای فرد</MudText>
            </MudStack>
            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Justify="Justify.Center">
                <MudText Typo="Typo.body1">صبح</MudText>
                <MudSwitch @bind-Checked="IsPm"></MudSwitch>
                <MudText Typo="Typo.body1">بعد از ظهر</MudText>
            </MudStack>
        </MudItem>
        <MudItem sm="12" md="6">
            <MudSelect Label="انتخاب روز های هفته" MultiSelection="true" @bind-SelectedValues="SelectedWeekdays">
                @foreach (var weekday in _weekdays)
                {
                    <MudSelectItem Value="weekday" Class="mud-rtl">
                        @weekday.Title @weekday.Id
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>


    </MudGrid>

    @if (IsSessionGenerator is true)
    {
        <MudAlert ShowCloseIcon="true" Icon="@Icons.Material.Filled.Info" Severity="Severity.Info">
            <MudText Typo="Typo.h5" Color="Color.Warning">
                می توانید با کلیک بر روی عنوان سانس ها، اگر جلسات برگزاری برای کلاسی تعریف نشده بود، جلسات را با توجه به قالب از پیش تعریف شده برای این ترم را ایجاد نمایید.
            </MudText>
        </MudAlert>
    }
    else if (IsSessionCanceler is true)
    {
        <MudAlert ShowCloseIcon="true" Icon="@Icons.Material.Filled.Light" Severity="Severity.Warning">
            <MudText Typo="Typo.caption">
                برای کنسل کردن یک کلاس بر روی دکمه
                <MudText Typo="Typo.caption" Color="Color.Error">
                    کنسل
                    <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error"></MudIcon>
                </MudText>
                کلیک نمایید. همچنین می توانید جهت کنسل کردن هر سانس بر روی دکمه
                <MudText Typo="Typo.caption" Color="Color.Error">
                    کنسل کردن کل سانس
                    <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error"></MudIcon>
                </MudText> روی نوار عنوان سانس کلیک کنید
                و برای کنسل کردن کل روز از دکمه
                <MudText Typo="Typo.caption" Color="Color.Error">
                    کنسل کردن تمام روز
                    <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error"></MudIcon>
                </MudText>
                استفاده نمایید
            </MudText>
        </MudAlert>

        <MudStack Row="true" Spacing="5">
            <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.TwoTone.Cancel" OnClick="CancellFulldayClick">
                کنسل کردن تمام روز

            </MudButton>

        </MudStack>

    }
    else
    {
        <MudStack Row="true" Spacing="5">
            <MudCheckBox @bind-Checked="ShowPrices" LabelPosition="LabelPosition.Start" Label="نمایش هزینه کلاس و کتاب"></MudCheckBox>
            <MudSwitch @bind-Checked="@dense" Color="Color.Secondary">نمایش بصورت فشرده</MudSwitch>
        </MudStack>

    }

    <CascadingValue Name="Parent" Value="(ICanChangeComponentState)this">


        @if (_intervals is not null)
                    {

        <MudSimpleTable Dense="@dense" Bordered="true" FixedHeader="true" Striped="true" Elevation="1">
            <thead>
                <tr>
                    <td style="width: 50px">
                    </td>
                    @foreach (var interval in _intervals)
                    {
                        <td style="@("width:" + (dense ?  "200px":"300px"))">
                            <MudChip Label="true" Color="Color.Info" Variant="Variant.Filled" Class="w-100" OnClick="()=>OpenGenerateSessionsDialogbyInterval(interval, SelectedWeekdays)">
                                @interval.Title
                                @if (IsSessionCanceler is true)
                                {
                                    <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.TwoTone.CancelPresentation" OnClick="() => IntervalCancelClick(interval)">
                                        کنسل کردن کل سانس
                                    </MudButton>
                                }
                            </MudChip>
                        </td>
                    }
                </tr>
            </thead>
            <tbody>

                @foreach (var classRoom in _classRooms)
                {
                    <tr>
                        <td>
                            <MudButton Style="width: 50px">
                                @classRoom.ClassRoomName
                            </MudButton>
                        </td>
                        @foreach (var interval in _intervals)
                        {
                                <td style="@("width:" + (dense ?  "200px":"300px"))">
                            
                                    @{
                                        var timeTable = GetTimeTable(interval, classRoom, SelectedWeekdays);
                                    }

                                    <TimeTableItemComponent Dense="@dense" Style="width: 100%;" TimeTable="timeTable" ShowSessionCount="true" IsSessionCanceler="IsSessionCanceler">
                                        <ChildContent>
                                            @if (ShowPrices && _prices != null)
                                            {
                                                <MudStack Row="true" Spacing="1">
                                                    <MudChip Color="Color.Info">
                                                        <MudChip Label="true" Color="Color.Dark" Size="Size.Large" Icon="@Icons.Material.Filled.Book">
                                                            کتاب:
                                                        </MudChip>
                                                        <MudText Typo="Typo.h6">
                                                            @_prices.FirstOrDefault(x=>x.LevelId == timeTable.LevelId)?.BookPrice.ToString("##,###") تومان
                                                        </MudText>
                                                    </MudChip>

                                                    <MudChip Color="Color.Tertiary">
                                                        <MudChip Label="true" Color="Color.Dark" Size="Size.Large" Icon="@Icons.Material.Filled.Money">
                                                            شهریه:
                                                        </MudChip>
                                                        <MudText Typo="Typo.h6">
                                                            @_prices.FirstOrDefault(x=>x.LevelId == timeTable.LevelId)?.TuitionAmount.ToString("##,###") تومان
                                                        </MudText>
                                                    </MudChip>

                                                </MudStack>
                                            }
                                            
                                        </ChildContent>
                                        <NoContent>
                                            <MudPaper Class="w-100 text-center" Elevation="0">
                                                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning"></MudIcon>
                                            </MudPaper>
                                        </NoContent>
                                    </TimeTableItemComponent>
                                </td>
                            }

                        </tr>

                        }
                </tbody>

            </MudSimpleTable>
                }

    </CascadingValue>

</MudContainer>





