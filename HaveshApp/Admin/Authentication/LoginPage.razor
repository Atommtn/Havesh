@page "/LoginPage"
@page "/LoginPage/{LogOutString}"
@attribute [AllowAnonymous]
@layout AuthenticationLayout
@using HaveshApp.Classes
@using Olive
@using Serilog
@using Log = Serilog.Log
@using Havesh.Model.Model

<MudPaper Class="m-3 p-3" Elevation="3">
    <MudGrid Class="m-3 p-3">
        <MudItem sm="12" md="12" xl="3">
            <MudText Typo="Typo.h5">Login</MudText>
            <MudDivider />
        </MudItem>
        <MudItem sm="12" md="6" xl="3">
            <MudTextField  @bind-Value="UserName" Label="User name"></MudTextField>
        </MudItem>
        <MudItem sm="12" md="6" xl="3">
            <MudTextField @bind-Value="Password" Label="Password" InputType="InputType.Password"></MudTextField>
        </MudItem>
    </MudGrid>
    <MudToolBar Class="m-2">
        <MudSpacer  />
        @if (!_loginCheck)
        {
            <MudButton Variant="Variant.Text" Color="Color.Success" StartIcon="@Icons.TwoTone.Login" OnClick="LoginClick">
                Login
            </MudButton> 
            

        }
        else
        {
            <MudProgressLinear Striped="true" Size="Size.Medium" Color="Color.Primary" Indeterminate="true" Class="my-7" />
        }
    </MudToolBar>
    <MudButton Variant="Variant.Text" Color="Color.Info" StartIcon="@Icons.TwoTone.ArrowBack" OnClick="BackClick">
        Back
    </MudButton>
    <MudText Typo="Typo.subtitle2" Color="Color.Default" >
        Version 1.7.0 - Update on 11 Feb (v7)
    </MudText>

    
</MudPaper>

@code {
    bool _loginCheck = false;
    public string UserName { get; set; }
    public string Password { get; set; }

    [Parameter] public string? LogOutString { get; set; }
    [Inject] AuthenticationService AuthenticationService { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (LogOutString is  "Logout")
            {
	            await AuthenticationService.LogOut();
            }
        }

        await base.OnAfterRenderAsync(firstRender);
    }


    async Task LoginClick()
    {
        if (UserName.IsEmpty() || Password.IsEmpty())
        {
            _snackBar.Add("Please enter username and password.", Severity.Info);
            return;
        }

        _loginCheck = true;
        StateHasChanged();
        await Task.Delay(100);

        try
	    {
	        var user = await AuthenticationService.Login(UserName, Password);
	    }
	    catch (AuthenticationService.InvalidUserCredentialException e)
	    {
		    Log.Error("Someone tried to login by user: {UserName} with Password: {Password}", UserName, Password);
            _snackBar.Add(e.Message, Severity.Error);
		    _loginCheck = false;
		    return;
	    }
	    catch (AuthenticationService.UserIsNotActiveException ex)
	    {
		    Log.Error("User {UserName} is Inactive but he(she) tried to login !",UserName);
            _snackBar.Add(ex.Message, Severity.Warning);
		    _loginCheck = false;
		    return;
	    }
        Log.Information("User {UserName} Successfully logged-in to application.",UserName);
    }
    [Inject] public BrowserService BrowserService { get; set; }

    private async Task BackClick()
    {
        await BrowserService.OpenInCurrentTabAsync($"https://haveshapp.ir");
    }
   

}
