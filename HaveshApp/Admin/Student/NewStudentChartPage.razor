@page "/NewStudentChart"
@using HaveshApp.Admin.DailyJV.Components
@using System.Globalization
@using DNTPersianUtils.Core
@using Havesh.Domain
@using Havesh.Model.Model
@using HaveshApp.Classes
<h3>تعداد ثبت ‌نام دانش‌آموزان جدید</h3>
<MudStack Class="pa">
    <MudCard Style="Width: 250px">
        <MudCardContent>
            <MudDatePicker @bind-Date="DateFrom"
                           Label="از تاریخ"
                           FirstDayOfWeek="DayOfWeek.Saturday"
                           Culture="@GetPersianCulture()"
                           MaxDate="DateTime.Today"
                           TitleDateFormat="dddd, dd MMMM" />
            <MudSpacer></MudSpacer>
            <MudDatePicker @bind-Date="DateTo"
                           Label="تا تاریخ"
                           FirstDayOfWeek="DayOfWeek.Saturday"
                           Culture="@GetPersianCulture()"
                           MaxDate="DateTime.Today"
                           TitleDateFormat="dddd, dd MMMM" />
        </MudCardContent>
    </MudCard>
</MudStack>
<MudButton Color="Color.Success" StartIcon="@Icons.Material.Filled.ShowChart" Variant="Variant.Text" OnClick="ShowChartClick">
    Show Chart
</MudButton>
@if (savedStudentsSeries is { Count: > 0 })
{
    <MudChart ChartType="ChartType.Bar" ChartSeries="@savedStudentsSeries" ChartOptions="ChartOp"
              @bind-SelectedIndex="Index"
              XAxisLabels="@XAxisLabels.ToArray()" Width="100%" Height="350px" />
}
@code {
    private int Index = 0; //default value cannot be 0 -> first selectedindex is 0.
    public DateTime? DateFrom { get; set; }
    public DateTime? DateTo { get; set; }
    public List<string> XAxisLabels;
    public ChartOptions ChartOp { get; set; }
    private List<ChartSeries> savedStudentsSeries;

    CultureInfo GetPersianCulture()
    {
        var culture = new CultureInfo("fa-IR");
        return culture;
    }

    private void ShowChartClick()
    {
        ChartOp = new ChartOptions
            {
                ChartPalette = new[] { "#3399FF", "#2ECC9A", "#F4C430" }
            };

        var result = _dataProvider.GetStudentCountsByGenderAndWeek(DateFrom.Value, DateTo.Value);
        savedStudentsSeries = result.Series;
        XAxisLabels = result.Labels;
    }
}