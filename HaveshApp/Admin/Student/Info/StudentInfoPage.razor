@page "/studentInfo/{StudentGuid?}"
@layout PersianPagesLayout


@using HaveshApp.Admin.Planning.Components
@using HaveshApp.Admin.Clone
@using HaveshApp.Admin.DailyJV.Components
@using HaveshApp.Admin.Student.Components
@using Havesh.Model.Model

<TermSelectorComponent @bind-Term="Term" />
<MudTabs>
	<MudTabPanel Text="مشخصات آموزشی">
		<MudGrid>
			<MudItem xs="12" md="6">
				@if (timeTable != null)
				{
					<TimeTableItemComponent ShowRecordId="true" TimeTable="timeTable">
						<ChildContent>
							@if (bookPrice != null)
							{
								<MudStack Row="true" Spacing="1">
									<MudChip Color="Color.Info">
										<MudChip Label="true" Color="Color.Dark" Size="Size.Large" Icon="@Icons.Material.Filled.Book">
											کتاب:
										</MudChip>
										<MudText Typo="Typo.h6">
											@bookPrice.BookPrice.ToString("##,###") تومان
										</MudText>
									</MudChip>

									<MudChip Color="Color.Tertiary">
										<MudChip Label="true" Color="Color.Dark" Size="Size.Large" Icon="@Icons.Material.Filled.Money">
											شهریه:
										</MudChip>
										<MudText Typo="Typo.h6">
											@bookPrice.TuitionAmount.ToString("##,###") تومان
										</MudText>
									</MudChip>

								</MudStack>
							}
						</ChildContent>
					</TimeTableItemComponent>
				}
			</MudItem>
		</MudGrid>

	</MudTabPanel>

	<MudTabPanel Text="واریز شهریه">
		<DailyJvRecordListComponent ShowRecordId="true" SelectedTerm="Term" Student="Student">

		</DailyJvRecordListComponent>
	</MudTabPanel>
	<MudTabPanel Text="مشخصات دانش آموز">
		<StudentInfoComponent Student="Student"></StudentInfoComponent>

	</MudTabPanel>
	<MudTabPanel Text="سابقه آموزشی">
		<StudentHistoryComponent Student="Student" OnTermChanged="Callback" ></StudentHistoryComponent>


	</MudTabPanel>
	<MudTabPanel Text="تخفیفات - توضیحات">
		<StudentSettingComponent TimeTableStudent="TimeTableStudent"></StudentSettingComponent>

	</MudTabPanel>
</MudTabs>
@code {

	[Inject]
	DataProviderService DataProvider { get; set; }

	private Guid? _studentGuid;

	ShokouhPardisYearClass Year;
	private ShokouhPardisTermClass? Term
	{
		get => _term;
		set
		{
			if (_term == value) return;
			_term = value;

			GetStudentClassByTerm(Student, Term);
			GetTimeTableStudentByTerm(Student, Term);
		}
	}

	private void GetTimeTableStudentByTerm(ShokouhPardisStudentClass student, ShokouhPardisTermClass term)
	{
		var shokouhPardisTimeTableStudent = _dataProvider.GetTimeTableStudent(student, term);
		if (shokouhPardisTimeTableStudent is null)
		{
			_snackBar.Add("برای این زبان آموز در این ترم رکوردی وجود ندارد" , Severity.Error);
		}
		else 
			TimeTableStudent = shokouhPardisTimeTableStudent;
	}

	//private List<ShokouhPardisTermClass> Terms;

	protected override void OnInitialized()
	{
		//Year = DataProvider.GetYearsInRange();
		//Terms = DataProvider.GetTerms(Year);
		Term = DataProvider.GetTermsInRangeToday();
		base.OnInitialized();
	}

	[Parameter]
	public string? StudentGuid
	{
		get => _studentGuid?.ToString("N");
		set
		{
			if (!Guid.TryParse(value, out var guid)) return;

			_studentGuid = guid;
			Student = DataProvider.GetStudentClassByGuid(_studentGuid);
		}
	}

	protected override void OnParametersSet()
	{
		if (Student is not null && Term is not null)
			GetStudentClassByTerm(Student, Term);

		base.OnParametersSet();
	}

	ShokouhPardisTimeTableStudent TimeTableStudent { get; set; }
	ShokouhPardisStudentClass? Student { get; set; }
	ShokouhPardisTimeTable? timeTable;
	ShokouhPardisLevelBookPrice? bookPrice;
	//List<ShokouhPardisDailyJv> StudentDailyJvs;
	private ShokouhPardisTermClass? _term;
	private ShokouhPardisTermClass _timeTableStudentTerm;

	void GetStudentClassByTerm(ShokouhPardisStudentClass? student, ShokouhPardisTermClass? term)
	{
		if (student == null)
			return;

		if (Term != null)
		{
			timeTable = DataProvider.GetStudentTermClass(student.Id, term.Id);
			//StudentDailyJvs = DataProvider.GetDailyJvBy(term.Id, student.Id);
		}

		if (timeTable != null)
			bookPrice = DataProvider.GetLevelBookPrice(timeTable);

	}


	private void Callback(ShokouhPardisTermClass term)
	{
		Term = term;
		StateHasChanged();
	}

}
