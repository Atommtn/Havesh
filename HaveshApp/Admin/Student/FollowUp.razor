@page "/FollowUp"

@using HaveshApp.Admin.Planning
@using HaveshApp.Admin.Student
@using HaveshApp.Admin.Clone
@using Serilog
@using HaveshApp.Admin.Authentication
@using Havesh.Model.Model
@layout PersianPagesLayout

@attribute [Authorize]

<StudentsListComponent AllowEdit="true"
                       Term="Term"
                       AllowDelete="true"
                       RowStyle="false"
                       @ref="StudentListComponent"
                       OnEditStudentAction="OnEditStudentAction"
                       OnDeleteStudentAction="OnDeleteStudentAction"> </StudentsListComponent>
<MudStack Row="true" AlignItems="AlignItems.End">

</MudStack>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center">
    @if (_isProgressing)
    {
        <MudProgressCircular Color="Color.Success" Indeterminate="true"></MudProgressCircular>
    }
</MudStack>


@code {
    [Inject] StudentService StudentService { get; set; }


    [Inject] IDialogService DialogService { get; set; }


    StudentsListComponent? StudentListComponent { get; set; }

    bool _isProgressing = false;
    ShokouhPardisTermClass? _term = null;

  



    private async Task StudentDialogButton(ShokouhPardisStudentClass student)
    {
        var Title = student.Id > 0 ? "Edit" : "New";
        var dialogReference = await DialogService.ShowAsync<AddNewStudentDialog>(
            Title + " Student",
            new DialogParameters
                {
                    ["Student"] = student
                },
            new DialogOptions()
                {
                    CloseOnEscapeKey = false,
                    CloseButton = false,
                    DisableBackdropClick = true,
                    MaxWidth = MaxWidth.Large
                });
        var dialogResult = await dialogReference.Result;
        if (dialogResult.Canceled == false)
        {
            var NewStudetent = (ShokouhPardisStudentClass)dialogResult.Data;
            StudentService.SaveStudent(NewStudetent);
            Log.Warning("User {UserName} {Title} Student {StudentId}", _userSession.Payload?.UserName, Title, NewStudetent.Id);
            await StudentListComponent.ReloadTableServerData();
            StateHasChanged();
        }
    }


    private async Task OnEditStudentAction(StudentActionArgs args)
    {

        await StudentDialogButton(args.Student);
    }



    private async Task<bool> OnDeleteStudentAction(StudentActionArgs args)
    {
        var result = await DialogService.ShowMessageBox("Delete student", $"Are you sure you want delete {args.Student.StudentName} {args.Student.StudentFamily} ?", "Yes", "No");
        if (result is true)
        {
            StudentService.DeleteStudent(args.Student);
            Log.Warning("User {UserName} Delete Student {StudentId}", _userSession.Payload?.UserName, args.Student.Id);
            return true;
        }
        return false;

    }

    public ShokouhPardisTermClass? Term
    {
        get => _term;
        set => _term = value;
    }

}
