@using System.ComponentModel
@using System.Diagnostics.Eventing.Reader
@using Havesh.Model.Model
@{
    if (ShowNothing)
    {
        <MudChip Label="true" Color="Color.Dark" Size="Size.Small">
            این دانش آموزش در ترم پیش کلاسی نداشته است. برای بررسی سوابق پرداخت به صفحه مشخصات آموزشی مراجعه نمایید.
            
        </MudChip>
    }
    else
    {
        var accStatus = AccountStatis(TimeTable);
        @if (accStatus == default)
        {
            <MudText Typo="Typo.body1">No Level Price</MudText>
        }
        else
        {
            @if (ShowTution)
            {
                <MudChip Label="true" Color="Color.Dark" Size="Size.Small">
                    شهریه ترم
                    <MudChip Size="Size.Small" Color="Color.Tertiary">@accStatus.ShehriehTerm.ToString("N0") تومان</MudChip>
                </MudChip>
            }

            <MudText Typo="Typo.body1">پرداختی ها :</MudText>
            @foreach (var x in accStatus.payments)
            {
                <MudChip Label="true" Color="Color.Dark" Size="Size.Small">
                    پرداختی بابت @x.Key
                    <MudChip Style="@GetFeeForStyle(x.Key)">@x.Value تومان</MudChip>
                </MudChip>
            }

            <MudText Typo="Typo.body1">وضعیت حساب :</MudText>
            <MudChip Label="true" Color="Color.Dark" Size="Size.Small">
                در ترم @TimeTable.Term.TermName شهریه
                @if (accStatus.Diff != 0)
                {
                    <text>به مبلغ</text>
                    <MudChip Color="Color.Info">@accStatus.Diff.ToString("N0") تومان</MudChip>
                }
                <MudChip Color="GetColor(accStatus.status)">@GetDescription(accStatus.status)</MudChip>
                است
            </MudChip>
        }
    }
}
@code {

	[Parameter]
	public bool ShowTution { get; set; }
	[Parameter]
	public ShokouhPardisTimeTable TimeTable { get; set; }

    [Parameter]
    public ShokouhPardisStudentClass Student { get; set; } 

    
    [Parameter]
    public bool LastTimeTable { get; set; } = false;
    
    public bool ShowNothing { get; set; }= false;

    protected override void OnParametersSet()
    {
        if (LastTimeTable && TimeTable is null)
        {
            var curretTerm = _dataProvider.GetTermsInRangeToday();
            var lastTimetable = _dataProvider.GetTimeTableByTermId(curretTerm.LastTermFk,Student.Id);
            if (lastTimetable is not null)
            {
                TimeTable = lastTimetable;
            }
            else
            {
                ShowNothing = true;
            }
    //todo پیدا کردن قبلی

        }
        base.OnParametersSet();
    }

	enum AccountBalanceTypeEnum
	{
		[Description("تسویه")]
		Settle,
		[Description("بدهکار")]
		Debtor,
		[Description("بستانکار")]
		Crediator
	}
	public static string GetDescription(Enum value)
	{
		var fieldInfo = value.GetType().GetField(value.ToString());
		var attribute = (DescriptionAttribute)Attribute.GetCustomAttribute(fieldInfo, typeof(DescriptionAttribute));
		return attribute != null ? attribute.Description : value.ToString();
	}

	private (int ShehriehTerm, Dictionary<string, int> payments, AccountBalanceTypeEnum status, int Diff) AccountStatis(ShokouhPardisTimeTable timeTable)
	{
		var levelBookPrice = _dataProvider.GetLevelBookPrice(timeTable);
		if (levelBookPrice == null)
		{
			return default;
		}
		var shahriehTerm = levelBookPrice.TuitionAmount;
		var djvs = _dataProvider.GetDailyJvBy(timeTable.TermId, Student.Id);
		var payments = djvs
							.GroupBy(x => x.FeeFor!)
							.ToDictionary(x => x.Key, y => y.Sum(z => z.Fee));
		var _status = AccountBalanceTypeEnum.Settle;
		int diff = shahriehTerm;
		if (payments.TryGetValue("شهریه", out var payedShahrieh))
		{
			diff = shahriehTerm - payedShahrieh;
			_status = diff switch
			{
				0 => AccountBalanceTypeEnum.Settle,
				> 0 => AccountBalanceTypeEnum.Debtor,
				_ => AccountBalanceTypeEnum.Crediator
			};
		}
		else
		{
			_status = AccountBalanceTypeEnum.Debtor;
		}
		return (shahriehTerm, payments, _status, diff);
	}


	private Color GetColor(AccountBalanceTypeEnum accStatusStatus)
	{
		return accStatusStatus switch
		{
			AccountBalanceTypeEnum.Settle => Color.Success,
			AccountBalanceTypeEnum.Debtor => Color.Error,
			AccountBalanceTypeEnum.Crediator => Color.Warning
		};
	}

	private string? GetFeeForStyle(string value)
	{
		var color = "#08714a";
		var opa = "";
		switch (value)
		{
			case "شهریه":
				opa = "ff";
				break;
			case "کتاب":
				opa = "80";
				break;
			default:
				opa = "99";
				break;
		}

		return "background-color:" + color + opa + ";color:#ffffff";
	}

    

}
