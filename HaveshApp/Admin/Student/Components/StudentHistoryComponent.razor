@using Admin.Planning.Components
@using Havesh.Model.Model

@code {
	private void RaiseOnTermChangedClick(ShokouhPardisTermClass term)
	{
		OnTermChanged.InvokeAsync(term);
	}
}


<MudTable @ref="_studentTables" Items="@studentHisory"
          RowsPerPage="100" >
    <HeaderContent>
        <MudTh>ترم</MudTh>
        <MudTh>استاد</MudTh>
        <MudTh>سطح</MudTh>
        <MudTh>ساعت برگزاری</MudTh>
            
    </HeaderContent>
    <RowTemplate >
	    <MudTd DataLabel="ترم">
            <MudChip Label="true" OnClick="() => RaiseOnTermChangedClick(context.Term)">@context.Term.TermName</MudChip>
		</MudTd>
        <MudTd DataLabel="نام استاد">@context.Teacher.FullName</MudTd>
        <MudTd DataLabel="سطح">@context.Level.LevelName</MudTd>
        <MudTd DataLabel="برنامه کلاسی">@context.Schedule.Title</MudTd>
            
    </RowTemplate>
    @* <RowTemplate>
        <MudTd>
        <TimeTableItemComponent ShowRecordId="true" TimeTable="context"></TimeTableItemComponent>
        </MudTd>
    </RowTemplate>
    *@
</MudTable>

    

