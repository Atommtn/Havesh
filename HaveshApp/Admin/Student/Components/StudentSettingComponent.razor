@using System.Globalization


<MudPaper Class="pa-2 ma-2" Outlined="true">
    <MudGrid>
        <MudItem md="6">
            <MudCheckBox @bind-Checked="ShowAmountValue" Label=" آیا میخواهید مبلغ تخفیف عددی مشخص باشد." LabelPosition="LabelPosition.Start">

            </MudCheckBox>
           
            @if (ShowAmountValue)
            {
                <MudTextField @bind-Value="TimeTableStudent.StudentAmountDiscount" Label="مبلغ تخفیف" ReadOnly="!ShowAmountValue" Immediate="false" @onblur="@(()=>SetPercent())" />
            }
        </MudItem>
        <MudItem md="6">
           
                <MudTextField  @bind-Value="TimeTableStudent.StudentPercentDiscount" Label="درصد تخفیف" ReadOnly="ShowAmountValue"/>
            
        </MudItem>
        <MudItem md="6">
            <MudCheckBox @bind-Checked="TimeTableStudent.IsBookPaymentComplete" Disabled="true" Label="پرداخت کتاب" LabelPosition="LabelPosition.Start"></MudCheckBox>
        </MudItem>
        <MudItem md="6">
            <MudCheckBox @bind-Checked="TimeTableStudent.IsPaymentComplete" Disabled="true" Label="پرداخت شهریه" LabelPosition="LabelPosition.Start"></MudCheckBox>
        </MudItem>
        <MudItem md="12">
            <MudTextField @bind-Value="TimeTableStudent.Description" Label="توضیحات" />
        </MudItem>
    </MudGrid>
</MudPaper>

    <MudButton Color="Color.Success" StartIcon="@Icons.Filled.Save" Variant="Variant.Filled" OnClick="SaveClick">
        ذخیره
    </MudButton>

