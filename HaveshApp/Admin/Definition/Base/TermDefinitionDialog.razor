@using HaveshApp.Admin.Components
@using Havesh.Model.Model
@using System.Globalization


<MtnDialog>
    <ChildComponent>
        @if (Term is { })
        {
            <MudGrid>
                <MudItem md="6">
                    <MudTextField @bind-Value="@Term.TermName" Required Label="نام ترم" />
                </MudItem>
                <MudItem md="6">

                    <MudDatePicker @bind-Date="Term.StartDate"
                                   Label="تاریخ شروع"
                                   FirstDayOfWeek="DayOfWeek.Saturday"
                                   Culture="@GetPersianCulture()"
                                   MaxDate="@MaxDate"
                                   TitleDateFormat="dddd, dd MMMM" />


                </MudItem>
                <MudItem md="6">
                     <MudDatePicker @bind-Date="Term.EndDate"
                                    Label="تاریخ پایان"
                                    FirstDayOfWeek="DayOfWeek.Saturday"
                                    Culture="@GetPersianCulture()"
                                    MaxDate="@MaxDate"
                                    TitleDateFormat="dddd, dd MMMM" />
                </MudItem>
                


         
                </MudGrid>
        }
    </ChildComponent>
    <DialogAction>
        <MudButton Color="Color.Success" StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" OnClick="SaveDialogClick">
            ذخیره
        </MudButton>

        <MudButton Color="Color.Warning" StartIcon="@Icons.Material.Filled.Close" Variant="Variant.Text" OnClick="CloseDialogClick">
            بستن
        </MudButton>
    </DialogAction>
</MtnDialog>


@code {

    [CascadingParameter]
    MudDialogInstance DialogInstance { get; set; }

    [Parameter]
    public ShokouhPardisTermClass? Term { get; set; }

    /// <summary>
    /// حداکثر تاریخ قابل انتخاب برای شروع/پایان ترم.
    /// پیش‌فرض null یعنی بدون محدودیت (برای دیالوگ ترم نباید محدود به امروز باشه).
    /// اگر در آینده جای دیگه‌ای این دیالوگ با نیاز به محدودیت "تا امروز" استفاده شد،
    /// می‌شه این پارامتر رو از بیرون پاس داد.
    /// </summary>
    [Parameter]
    public DateTime? MaxDate { get; set; } = null;


    CultureInfo GetPersianCulture()
    {
        var culture = new CultureInfo("fa-IR");
        return culture;
    }
    protected override void OnInitialized()
    {

        base.OnInitialized();
    }

    private void CloseDialogClick()
    {
        DialogInstance.Cancel();
    }

    private void SaveDialogClick()
    {
        DialogInstance.Close(Term);
    }
}