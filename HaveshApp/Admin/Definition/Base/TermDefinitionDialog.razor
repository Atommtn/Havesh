@using HaveshApp.Admin.Components
@using Havesh.Model.Model
@using System.Globalization


<MtnDialog>
    <ChildComponent>
        @if (Term is { })
        {
            <MudGrid>
                <MudItem md="6">
                    <MudTextField @bind-Value="@Term.TermName" Required Label="نام ترم" />
                </MudItem>
                <MudItem md="6">

                    <MudDatePicker @bind-Date="Term.StartDate"
                                   Label="تاریخ شروع"
                                   FirstDayOfWeek="DayOfWeek.Saturday"
                                   Culture="@GetPersianCulture()"
                                   MaxDate="@MaxDate"
                                   TitleDateFormat="dddd, dd MMMM" />


                </MudItem>
                <MudItem md="6">
                     <MudDatePicker @bind-Date="Term.EndDate"
                                    Label="تاریخ پایان"
                                    FirstDayOfWeek="DayOfWeek.Saturday"
                                    Culture="@GetPersianCulture()"
                                    MaxDate="@MaxDate"
                                    TitleDateFormat="dddd, dd MMMM" />
                </MudItem>

                @if (Term.Id > 0)
                {
                    <MudItem md="6">
                        <MudSelect @bind-Value="Term.LastTermFk" Label="ترم قبلی" Dense="true" Clearable="true">
                            @foreach (var t in OtherTerms)
                            {
                                <MudSelectItem Value="@((int?)t.Id)">@t.TermName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem md="6">
                        <MudSelect @bind-Value="Term.NextTermFk" Label="ترم بعدی" Dense="true" Clearable="true">
                            @foreach (var t in OtherTerms)
                            {
                                <MudSelectItem Value="@((int?)t.Id)">@t.TermName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }


                </MudGrid>
        }
    </ChildComponent>
    <DialogAction>
        <MudButton Color="Color.Success" StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" OnClick="SaveDialogClick">
            ذخیره
        </MudButton>

        <MudButton Color="Color.Warning" StartIcon="@Icons.Material.Filled.Close" Variant="Variant.Text" OnClick="CloseDialogClick">
            بستن
        </MudButton>
    </DialogAction>
</MtnDialog>


@code {

    [CascadingParameter]
    MudDialogInstance DialogInstance { get; set; }

    [Inject] DataProviderService DataProvider { get; set; }

    [Parameter]
    public ShokouhPardisTermClass? Term { get; set; }

    /// <summary>
    /// حداکثر تاریخ قابل انتخاب برای شروع/پایان ترم.
    /// پیش‌فرض null یعنی بدون محدودیت (برای دیالوگ ترم نباید محدود به امروز باشه).
    /// اگر در آینده جای دیگه‌ای این دیالوگ با نیاز به محدودیت "تا امروز" استفاده شد،
    /// می‌شه این پارامتر رو از بیرون پاس داد.
    /// </summary>
    [Parameter]
    public DateTime? MaxDate { get; set; } = null;

    /// <summary>
    /// لیست بقیه‌ی ترم‌ها برای انتخاب دستی "ترم قبلی"/"ترم بعدی" در حالت ویرایش.
    /// فقط وقتی Term.Id > 0 (ویرایش) نمایش داده می‌شه؛ موقع ساخت ترم جدید این فیلدها دیده نمی‌شن
    /// چون لینک‌شدن به ترم قبلی به‌صورت خودکار (بر اساس تاریخ) در SaveEditTerm انجام می‌شه.
    /// </summary>
    private List<ShokouhPardisTermClass> OtherTerms = new();

    CultureInfo GetPersianCulture()
    {
        var culture = new CultureInfo("fa-IR");
        return culture;
    }
    protected override void OnInitialized()
    {
        if (Term is not null)
        {
            OtherTerms = DataProvider.GetAllTerms().Where(x => x.Id != Term.Id).ToList();
        }

        base.OnInitialized();
    }

    private void CloseDialogClick()
    {
        DialogInstance.Cancel();
    }

    private void SaveDialogClick()
    {
        DialogInstance.Close(Term);
    }
}
