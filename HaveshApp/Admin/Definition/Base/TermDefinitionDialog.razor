@using HaveshApp.Admin.Components
@using Havesh.Model.Model
@using System.Globalization


<MtnDialog>
    <ChildComponent>
        @if (Term is { })
        {
            <MudGrid>
                <MudItem md="6">
                    <MudTextField @bind-Value="@Term.TermName" Required Label="نام ترم" />
                </MudItem>
                <MudItem md="6">
                     
                    <MudDatePicker @bind-Date="Term.StartDate"
                                   Label="تاریخ شروع"
                                   FirstDayOfWeek="DayOfWeek.Saturday"
                                   Culture="@GetPersianCulture()"
                                   MaxDate="DateTime.Today"
                                   TitleDateFormat="dddd, dd MMMM" />
                    
                    
                </MudItem>
                <MudItem md="6">
                     <MudDatePicker @bind-Date="Term.EndDate"
                                    Label="تاریخ پایان"
                                    FirstDayOfWeek="DayOfWeek.Saturday"
                                    Culture="@GetPersianCulture()"
                                    MaxDate="DateTime.Today"
                                    TitleDateFormat="dddd, dd MMMM" />
                </MudItem>

                @if (Term.Id > 0)
                {
                    @* ترم جدید موقع ساخت به‌صورت خودکار بر اساس تاریخ به نزدیک‌ترین ترم قبلی لینک می‌شود.
                       این دو فیلد فقط برای ویرایش/اصلاح دستی آن لینک در ترم‌های موجود هستند. *@
                    <MudItem md="6">
                        <MudSelect T="int?" @bind-Value="Term.LastTermFk" Label="ترم قبلی" Dense="true" Clearable="true">
                            @foreach (var t in OtherTerms)
                            {
                                <MudSelectItem T="int?" Value="@((int?)t.Id)">@t.TermName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem md="6">
                        <MudSelect T="int?" @bind-Value="Term.NextTermFk" Label="ترم بعدی" Dense="true" Clearable="true">
                            @foreach (var t in OtherTerms)
                            {
                                <MudSelectItem T="int?" Value="@((int?)t.Id)">@t.TermName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }


         
                </MudGrid>
        }
    </ChildComponent>
    <DialogAction>
        <MudButton Color="Color.Success" StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" OnClick="SaveDialogClick">
            ذخیره
        </MudButton>

        <MudButton Color="Color.Warning" StartIcon="@Icons.Material.Filled.Close" Variant="Variant.Text" OnClick="CloseDialogClick">
            بستن
        </MudButton>
    </DialogAction>
</MtnDialog>


@code {

    [Inject] DataProviderService DataProvider { get; set; }

    [CascadingParameter]
    MudDialogInstance DialogInstance { get; set; }

    [Parameter]
    public ShokouhPardisTermClass? Term { get; set; }

    // لیست بقیه‌ی ترم‌ها (به‌جز خود این ترم) برای انتخاب دستی "ترم قبلی/بعدی"
    List<ShokouhPardisTermClass> OtherTerms { get; set; } = new();

    CultureInfo GetPersianCulture()
    {
        var culture = new CultureInfo("fa-IR");
        return culture;
    }
    protected override void OnInitialized()
    {
        if (Term is { Id: > 0 })
        {
            OtherTerms = DataProvider.GetAllTerms()
                .Where(x => x.Id != Term.Id)
                .ToList();
        }

        base.OnInitialized();
    }

    private void CloseDialogClick()
    {
        DialogInstance.Cancel();
    }

    private void SaveDialogClick()
    {
        DialogInstance.Close(Term);
    }
}