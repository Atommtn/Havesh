@using ShokouhApp.Services
@using ShokouhApp.Model
@using ShokouhApp.Admin.Components


<MtnDialog>
    <ChildComponent>

        <MudGrid>
            <MudItem md="6">
                <MudSelect @bind-Value="@DaySession.WeekDay" Label="روز" Dense="true">
                    @foreach (var weekDay in _weekdays)
                    {
                        <MudSelectItem Value="weekDay">@weekDay.Title</MudSelectItem>
                    }
                </MudSelect>


            </MudItem>
            <MudItem md="6">
                <MudSelect @bind-Value="@DaySession.Interval" Label="سانس" Dense="true">
                    @foreach (var interval in _intervals)
                    {
                        <MudSelectItem Value="interval">@interval.Title</MudSelectItem>
                    }
                </MudSelect>

            </MudItem>



        </MudGrid>
    </ChildComponent>
    <DialogAction>
        <MudButton Color="Color.Success" StartIcon="@Icons.Filled.Save" Variant="Variant.Filled" OnClick="SaveDialogClick">
            ذخیره
        </MudButton>

        <MudButton Color="Color.Warning" StartIcon="@Icons.Filled.Close" Variant="Variant.Text" OnClick="CloseDialogClick">
            بستن
        </MudButton>
    </DialogAction>
</MtnDialog>


@code {

    [CascadingParameter]
    MudDialogInstance DialogInstance { get; set; }
    [Inject] DataProviderService DataProvider { get; set; }

    [Parameter] public ShokouhPardisDaySession? DaySession { get; set; }
    
    [Parameter] public ShokouhPardisTermClass? SelectedTerm { get; set; }

    private List<ShokouhPardisWeekDay> _weekdays;
    private List<ShokouhPardisInterval> _intervals;

    protected override void OnInitialized()
    {
        _weekdays = DataProvider.GetWeekDays();
        _intervals = DataProvider.GetIntervals(SelectedTerm);
        base.OnInitialized();
    }

    private void CloseDialogClick()
    {
        DialogInstance.Cancel();
    }

    private void SaveDialogClick()
    {

        DialogInstance.Close(DaySession);
    }
}
