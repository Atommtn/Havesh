@using Havesh.Model.Model
<style type="text/css" media="all">
    .mud-table-head{
        background-color: #237a93;
        }
</style>
<MtnDialog>
    <ChildComponent>
       
        <h3>@SectionTypeTitle </h3>
        
        <MudTable @ref="table"
                  Hover="true"
                  Breakpoint="Breakpoint.None"
                  Items="SectionItems"
                  Style="background-color: #355167;">
            <ToolBarContent>
                
                <MudButton Color="Color.Success" StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Text" OnClick="NewSectionItemClick">
                    Add Section Item
                </MudButton>

            </ToolBarContent>
            <HeaderContent >
                <MudTh>Item Title</MudTh>
                <MudTh>Order</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate Context="secItem">
                <MudTd>@secItem.SectionItemTitle </MudTd>
                <MudTd>@secItem.Order </MudTd>
                <MudTd>
                    <MudIconButton ButtonType="ButtonType.Button" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="() => EditButtonClick(secItem)"></MudIconButton>

                </MudTd>

            </RowTemplate>

    

        </MudTable>
     
    </ChildComponent>
    <DialogAction>
  
        <MudButton Color="Color.Warning" StartIcon="@Icons.Material.Filled.Close" Variant="Variant.Text" OnClick="CloseDialogClick">
            بستن
        </MudButton>
    </DialogAction>
</MtnDialog>

@code {

    
    [Inject] ISnackbar Snackbar { get; set; }
    MudTable<LessonPlanSectionItem>? table;
    public List<LessonPlanSectionItem> SectionItems { get; set; }

    [CascadingParameter]
    MudDialogInstance DialogInstance { get; set; }

    [Parameter]
    public LessonPlanSection? Section { get; set; }
    [Parameter]
    public String? SectionTypeTitle { get; set; }

    public string? NewSectionItemTitle { get; set; }
    public int NewSectionItemOrder { get; set; }
    public bool _changes = false;

    protected override void OnInitialized()
    {
        
        RefreshData();
        base.OnInitialized();
    }

    private void RefreshData()
    {

        SectionItems = _dataProvider.GetLessonPlanSectionItems(Section);

    }

    private void CloseDialogClick()
    {
        DialogInstance.Close(DialogResult.Ok(_changes));
    }

 
    private async Task OpenNewEditSectionItem(LessonPlanSectionItem secItem)
    {
        var dialogReference = _dialogService.Show<LessonPlanNewSectionItemDialog>(
            (secItem.Id > 0 ? "Edit " : "New ") + "Section Item ",
            new DialogParameters
            {
             ["SectionItem"] = secItem
            },
            new DialogOptions()
            {
                CloseButton = true,
                MaxWidth = MaxWidth.ExtraLarge
            });

        var dialogResult = await dialogReference.Result;
            if (dialogResult.Canceled == false)
            {
                
                var retData = (LessonPlanSectionItem)dialogResult.Data;
                 _dataProvider.SaveSectionItem(retData);
                 
                Snackbar.Add("New Section Item Succsecfullu Add", Severity.Success);
                Log.Warning("User {UserName} Save-Update Section Item {SectionItemId}",
                            _userSession.Payload.UserName, retData.Id);
                RefreshData();
                StateHasChanged(); 
            }
      

       
    }

    private void EditButtonClick(LessonPlanSectionItem secItem)
    {
        OpenNewEditSectionItem(secItem);
        
    }

    private void NewSectionItemClick()
    {
        var secItem = new LessonPlanSectionItem()
        {
            Guid = new Guid(),
            CreatedWhen = DateTime.Now,
            LessonPlanSectionFk = Section.LessonPlanFk,
            Section = Section
        };
        OpenNewEditSectionItem(secItem);
    }

}
