@using HaveshApp.Admin.Components
@using Havesh.Model.Model


<MtnDialog>
    <ChildComponent>
        <MudGrid>
            <MudItem md="6">
                <MudTextField @bind-Value="@Section.Order" Required Label="Section Order" />
             </MudItem>
             <MudItem md="6">
                 <MudSelect @bind-Value="Section.SectionTypeFk" Label="Section Type" Dense="true">
                     @foreach (var st in SectionType)
                     {
                         <MudSelectItem Value="st.Id">@st.Title</MudSelectItem>
                     }
                 </MudSelect>
             </MudItem>
             <MudItem md="6">
                 <MudTextField @bind-Value="@Section.SectionTitle" Required Label="Section Title" />
             </MudItem>
             <MudItem md="6">
                 <MudTextField @bind-Value="@Section.Duration" Required Label="Section Duration" />
             </MudItem>
             <MudItem md="6">
                 <MudTextField @bind-Value="@Section.SectionObjective" Required Label="Section Objective" />
             </MudItem>

         </MudGrid>
     </ChildComponent>
     <DialogAction>
         <MudButton Color="Color.Success" StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" OnClick="SaveDialogClick">
             Save
         </MudButton>

         <MudButton Color="Color.Warning" StartIcon="@Icons.Material.Filled.Close" Variant="Variant.Text" OnClick="CloseDialogClick">
             Close
         </MudButton>
     </DialogAction>
 </MtnDialog>


 @code {

    [CascadingParameter]
    MudDialogInstance DialogInstance { get; set; }

    [Parameter]
    public LessonPlanSection Section { get; set; }
     public List<LessonPlanSectionType> _sectionType;
     public List<LessonPlanSectionType> SectionType
     {
        get => _sectionType;
         set
         {
            _sectionType = value;
             

         }
     }


     protected override void OnInitialized()
    {
         SectionType = _dataProvider.GetSectionType();
        base.OnInitialized();
    }

    private void CloseDialogClick()
    {
        DialogInstance.Cancel();
    }

    private void SaveDialogClick()
    {
        DialogInstance.Close(Section);
    }


    
 }
