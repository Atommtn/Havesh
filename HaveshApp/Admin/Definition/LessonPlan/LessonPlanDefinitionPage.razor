@page "/LessonPlanDefinition"
@using HaveshApp.Admin.Clone

@layout PersianPagesLayout

<h3>LessonPlan</h3>

<LevelSelectorComponenet @bind-Level="SelectedLevel"></LevelSelectorComponenet>


<MudTable @ref="table"
          Hover="true"
          Breakpoint="Breakpoint.None"
          Items="LessonPlans"
          Style="background-color: #3c4043;">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Lesson Plan Table</MudText>
        <MudSpacer />
        <MudButton Color="Color.Success" StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Text" OnClick="NewLessonPlanClick">
            Add New Lesson Plan
        </MudButton>

    </ToolBarContent>
    <HeaderContent>
        <MudTh>SessionNumber</MudTh>
        <MudTh>Title</MudTh>
        <MudTh></MudTh>

    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.SessionNumber</MudTd>
        <MudTd>@context.Title</MudTd>


        <MudTd>
            <MudIconButton ButtonType="ButtonType.Button" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="() =>EditButtonClick(context)"></MudIconButton>
        </MudTd>


    </RowTemplate>
    <ChildRowContent>
        <MudTr>
            <MudTd colspan="3">
                <SectionListComponent LessonPlanItem="@context"></SectionListComponent>
            </MudTd>
        </MudTr>
    </ChildRowContent>


</MudTable>
