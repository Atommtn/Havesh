@using Havesh.Model.Model
<style type="text/css" media="all">
    .SectionList .mud-table-row {
        background-color: darkcyan;
        }
    
</style>
<MudTable @ref="table"
          Hover="true"
          Breakpoint="Breakpoint.None"
          Items="Sections"
          Class="SectionList"
          Style="background-color: #3c4043; width:100%">
    <ToolBarContent>
                  
        <MudButton Color="Color.Success" StartIcon="@Icons.Filled.Add" Variant="Variant.Text" OnClick="NewSectionClick">
            Add Section
        </MudButton>

    </ToolBarContent>
    <HeaderContent>
        <MudTh>SectionType</MudTh>
        <MudTh>Title</MudTh>
        <MudTh>Duration</MudTh>
        <MudTh>SelectionObjective</MudTh>
        <MudTh></MudTh>
        <MudTh></MudTh>

    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.SectionType </MudTd>
        <MudTd>@context.SectionTitle</MudTd>
        <MudTd>@context.Duration</MudTd>
        <MudTd>@context.SectionObjective</MudTd>
        <MudTd>
            <MudButton Color="Color.Success" Variant="Variant.Text" OnClick="()=>ShowItems(context)">
               Show Items
            </MudButton>
        </MudTd>
        
        <MudTd>
            <MudIconButton ButtonType="ButtonType.Button" Icon="@Icons.Material.Filled.PlaylistAddCircle" Size="Size.Small" OnClick="() => AddEditSectionItemClick(context)"></MudIconButton>
        </MudTd>

    </RowTemplate>
    <ChildRowContent >
        @if (context.ShowDetail)
        {
            <MudTr>
                <MudTd colspan="6">
                    <LessonPlanSectionItemListViewComponent Section="context"></LessonPlanSectionItemListViewComponent>
                </MudTd>
            </MudTr>
        }
    </ChildRowContent>
    

</MudTable>


