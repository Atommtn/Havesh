@page "/Settings"
@layout PersianPagesLayout

<h3>Basic Setting Page</h3>
<MudCard>
	<MudCardHeader>
		<MudText Typo="Typo.body1">Settings</MudText>
	</MudCardHeader>
	<MudCardContent>
		<MudGrid Spacing="1">
			<MudItem md="6">
				<MudCheckBox @bind-Checked="IsDebug" Label="Is Debug Enable"></MudCheckBox>
			</MudItem>
			<MudItem md="6">
				<MudDatePicker @bind-Date="DebugDate" Label="Select Date"></MudDatePicker>
			</MudItem>
			<MudItem md="6">
				<MudTimePicker  @bind-Time="DebugTime" Label="Select Time" ></MudTimePicker>
			</MudItem>

		</MudGrid>

	</MudCardContent>
	<MudCardActions>
		<MudButton Variant="Variant.Text" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Close" OnClick="UpdateUserSession">
			Update User Session
		</MudButton>

	</MudCardActions>
</MudCard>

@code {

	public bool? IsDebug { get; set; } = true;

	public DateTime? DebugDate { get; set; } = DateTime.Parse("2023-12-16");
	public TimeSpan? DebugTime { get; set; } = TimeSpan.Parse("14:00");

	private void UpdateUserSession()
	{
		_userSession.Debug = new UserSessionService.DebugSetting(IsDebug, DebugDate, DebugTime);
	}

}
