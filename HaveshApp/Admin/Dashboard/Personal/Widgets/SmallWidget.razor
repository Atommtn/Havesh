@using Olive
@using System.Linq
@inherits WidgetBase

<ItemContainerWidget BreakPoints="@BreakPoints">
	<MudPaper Class="d-flex flex-row pt-4 pb-4" Style="@($"height:{Height};")">
		<MudIcon Icon="@Icon"
				 Color="@(IconColor ?? Color.Info)"
				 Class="mx-4"
				 Style=@($"width:{IconSize}px; height:{IconSize}px;")></MudIcon>
		<MudStack Row="@(IsInline is true)">
			<MudText Typo="Typo.subtitle1" Class="@($"{TitleClass} mb-n1")">@Title</MudText>
			<MudText Typo="Typo.h6">
				@if (@ChildContent is not null)
				{
					@ChildContent
				}
				else
				{
					@Value
				}
			</MudText>

		</MudStack>

	</MudPaper>
</ItemContainerWidget>

