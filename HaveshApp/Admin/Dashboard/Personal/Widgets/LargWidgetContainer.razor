@using Havesh.Model.Data.Dashboard
@inherits WidgetContainerBase

<LargWidget Title="@(Title ?? WidgetSetting.Title ?? WidgetSetting.Widget.Title)"
            Icon="@(WidgetSetting.Icon ?? WidgetSetting.Widget.Icon)"
            IconColor="@(WidgetSetting.IconColor ?? WidgetSetting.Widget.IconColor)"
            Height="@(WidgetSetting.Height ?? WidgetSetting.Widget.Height)"
            IconSize="@(WidgetSetting.IconSize ?? WidgetSetting.Widget.IconSize)"
            TitleClass="@(WidgetSetting.TitleClass ?? WidgetSetting.Widget.TitleClass)"
            BreakPoints="@(WidgetSetting.BreakPoints ?? WidgetSetting.Widget.BreakPoints)">
	
	<AuthorizeView Roles="@ToRoles">
		<Authorized>
			@if (ViewRequired == null)
			{
				<MudProgressCircular Indeterminate="true" Size="Size.Medium" Color="Color.Primary"/>
			}
			else
			{
				@ChildContent
			}
		</Authorized>
		<NotAuthorized>
			<MudAlert Severity="Severity.Warning" Dense="true">Not Access Permited !</MudAlert>
		</NotAuthorized>
	</AuthorizeView>

</LargWidget>

@code {

	[Parameter]
	public string? Title { get; set; }
}
