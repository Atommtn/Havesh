<ItemContainerWidget BreakPoints="@BreakPoints">
    <MudCard Style="height:100%;">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@Title</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent Class="px-0">
            @ChildContent
        </MudCardContent>
    </MudCard>
</ItemContainerWidget>
@code {

    [Parameter]
    public RenderFragment ChildContent { get; set; }

    [Parameter]
    public string Title { get; set; }

    [Parameter]
    public string? BreakPoints { get; set; }

}
