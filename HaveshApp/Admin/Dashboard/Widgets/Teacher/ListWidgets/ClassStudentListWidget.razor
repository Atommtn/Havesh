@using HaveshApp.Admin.Dashboard.Personal.Widgets
@using Havesh.Model.Model
@using Olive

@inherits HaveshApp.Admin.DashboardManagement.WidgetResolvers.WidgetResolverBase

<LargWidgetContainer WidgetSetting="WidgetSetting" ViewRequired="_students" ToRoles="...Teacher">
	<MudTable T="ShokouhPardisStudentClass"
			  Items="_students"
			  Bordered="true"
			  Breakpoint="Breakpoint.Xs"
			  Dense="true"
			  Class="p-3">
		<HeaderContent>
			<MudTh>ردیف</MudTh>
			<MudTh>نام</MudTh>
			<MudTh>نام خانوادگی</MudTh>
			<MudTh>وضعیت</MudTh>
		</HeaderContent>
		<RowTemplate>
			<MudTd DataLabel="ردیف">@(_students.IndexOf(context) + 1)</MudTd>
				<MudTd DataLabel="نام">@context.StudentName</MudTd>
				<MudTd DataLabel="نام خانوادگی">@context.StudentFamily</MudTd>
				<MudTd DataLabel="وضعیت"></MudTd>
			</RowTemplate>
		</MudTable>
	</LargWidgetContainer>

@code {

	IEnumerable<ShokouhPardisStudentClass>? _students;

	[Inject] public required TeacherWidgetsService TeacherWidgetsService { get; set; }
	int X = 0;
	protected override async Task OnInitializedAsync()
	{
		Console.WriteLine(X++);

		_students = await TeacherWidgetsService.GetTimeTableStudents();
		await base.OnInitializedAsync();
	}

}
