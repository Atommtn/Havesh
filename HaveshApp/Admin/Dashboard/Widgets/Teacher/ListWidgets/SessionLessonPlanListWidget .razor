@using HaveshApp.Admin.Dashboard.Personal.Widgets
@using Havesh.Model.Model
@using HaveshApp.Admin.Definition.LessonPlan
@using Olive

@inherits HaveshApp.Admin.DashboardManagement.WidgetResolvers.WidgetResolverBase

<LargWidgetContainer WidgetSetting="WidgetSetting" ViewRequired="_session" ToRoles="...Teacher">
	
	<TeacherLessonPlanComponent Session="_session">

	</TeacherLessonPlanComponent>

</LargWidgetContainer>

@code {

	TimeTableSession? _session;

	[Inject] public required TeacherWidgetsService TeacherWidgetsService { get; set; }
	protected override async Task OnInitializedAsync()
	{
		_session = await TeacherWidgetsService.GetTimeTableSession();

		await base.OnInitializedAsync();
	}

}
