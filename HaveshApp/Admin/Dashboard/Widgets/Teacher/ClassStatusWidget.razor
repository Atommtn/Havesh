@using HaveshApp.Admin.Dashboard.Personal.Widgets
@using Havesh.Model.Data.Dashboard
@using Havesh.Model.Model
@inherits HaveshApp.Admin.DashboardManagement.WidgetResolvers.WidgetResolverBase

<SmallWidgetContainer WidgetSetting="WidgetSetting" ViewRequired="_timetableSession">
	@_timetableSession?.SessionStatus
</SmallWidgetContainer>

@code {

	TimeTableSession? _timetableSession;

	[Inject] public required TeacherWidgetsService TeacherWidgetsService { get; set; }
	protected override async Task OnInitializedAsync()
	{
		_timetableSession = await TeacherWidgetsService.GetTimeTableSession();
		await base.OnInitializedAsync();
	}


}