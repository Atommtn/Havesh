@using HaveshApp.Admin.Dashboard.Personal.Widgets
@using Havesh.Model.Data.Dashboard
@using DNTPersianUtils.Core
@inherits HaveshApp.Admin.DashboardManagement.WidgetResolvers.WidgetResolverBase

<SmallWidgetContainer WidgetSetting="WidgetSetting" ViewRequired="false">
    @Calendar
</SmallWidgetContainer>

@code
{
	public string Calendar { get; set; }
	protected override void OnInitialized()
	{
		Calendar = _userSession.Debug is { IsDebug: true} 
			? _userSession.Debug.date.ToPersianDateTextify() 
			: DateTime.Today.AddDays(1).ToPersianDateTextify(true);
		base.OnInitialized();
	}
}
