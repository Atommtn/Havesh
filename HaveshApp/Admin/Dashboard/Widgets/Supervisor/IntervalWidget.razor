@using HaveshApp.Admin.Dashboard.Personal.Widgets
@using Havesh.Model.Data.Dashboard
@using DNTPersianUtils.Core
@using Havesh.Model.Model
@using HaveshApp.Admin.Dashboard.Widgets.Teacher
@inherits HaveshApp.Admin.DashboardManagement.WidgetResolvers.WidgetResolverBase

<SmallWidgetContainer WidgetSetting="WidgetSetting" ViewRequired="_interval" ToRoles="...Supervisor">
    @_interval?.Title
</SmallWidgetContainer>

@code
{
	private ShokouhPardisInterval? _interval;

	[Inject]
	public required SupervisorWidgetsService SupervisorWidgetsService { get; set; }

	protected override async Task OnInitializedAsync()
	{
		_interval = await SupervisorWidgetsService.GetInterval();
		await base.OnInitializedAsync();
	}

}
