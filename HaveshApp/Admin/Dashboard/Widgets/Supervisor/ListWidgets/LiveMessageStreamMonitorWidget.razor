@implements IAsyncDisposable
@inherits HaveshApp.Admin.DashboardManagement.WidgetResolvers.WidgetResolverBase
@using HaveshApp.Admin.Dashboard.Personal.Widgets
@using HaveshApp.Admin.Dashboard.Widgets.Teacher
@using Havesh.Model.Model
@using Havesh.GrainInterfaces.Common
@using Havesh.OrleansClient
@using Orleans.Runtime
@using Orleans.Streams
@using Havesh.Common

<LargWidgetContainer WidgetSetting="WidgetSetting" ToRoles="@WidgetSetting.Widget.BelongToRoles">
	<MudStack Row="false" Style="max-height: 100%;overflow-y: scroll">
		<MudPaper Outlined="true" Elevation="1">
			@foreach (var msg in _testMessage)
			{
				<MudChip Label="true" Size="Size.Small" Color="@(msg.Item2.ActivityDeletedDateTime is null ? Color.Info : Color.Error)">@msg.Item1</MudChip>
			}
		</MudPaper>
	</MudStack>
</LargWidgetContainer>

@code {


	[Inject] IClusterClient ClusterClient { get; set; }

	[Inject] SupervisorWidgetsService SupervisorWidgetsService { get; set; } = null!;
	readonly List<(string, StudentSessionActivity)> _testMessage = new();
	private StreamSubscriptionHandle<StudentSessionActivity>? _streamSubscriptionHandle;

	private async Task InitSubscribeToStudentActivityPerformAsync()
	{
		if (_streamSubscriptionHandle != null)
			await _streamSubscriptionHandle.UnsubscribeAsync();

		var streamProvider = ClusterClient.GetStreamProvider(HaveshConstants.OrleansSimpleMessageProviderName);
		var stream1 = streamProvider.GetStream<StudentSessionActivity>(
			StreamId.Create(HaveshConstants.StudentSessionActivityStreamNamespace, HaveshConstants.GeneralKey));
		var consumer = new HaveshStreamConsumer<StudentSessionActivity>(OnStudentActivityPerformedEvent);
		_streamSubscriptionHandle = await stream1.SubscribeAsync(consumer);
	}

	protected override async Task OnInitializedAsync()
	{
		await InitSubscribeToStudentActivityPerformAsync();
		await base.OnInitializedAsync();
	}

	private async Task OnStudentActivityPerformedEvent(StudentSessionActivity arg)
	{


		await InvokeAsync(() =>
		{
			if (arg.ActivityDeletedDateTime is not null)
			{
				_testMessage.Add(($"حدف {arg.Activity.ActivityTitle} " +
									$"زبان آموز {arg.Student.FullName} " +
									$"در کلاس {arg.TimeTableSession.ClassRoom.ClassRoomName} " +
									$"مدرس {arg.TimeTableSession.Teacher?.FullName ?? arg.TimeTableSession.TimeTable?.Teacher?.FullName} " +
									$"از {arg.ActivityValueOption?.Title} انجام شد." , arg )
					);
				StateHasChanged();
				return;
			}
			_testMessage.Add(($"{arg.Activity.ActivityTitle} " +
								$"زبان آموز {arg.Student.FullName} " +
								$"در کلاس {arg.TimeTableSession.ClassRoom.ClassRoomName} " +
								$"مدرس {arg.TimeTableSession.Teacher?.FullName ?? arg.TimeTableSession.TimeTable?.Teacher?.FullName} " +
								$"{arg.ActivityValueOption?.Title} " +
								$"ثبت شد",arg ));
			StateHasChanged();
		});
	}

	public async ValueTask DisposeAsync()
	{
		if (_streamSubscriptionHandle != null) await 
			_streamSubscriptionHandle.UnsubscribeAsync();
	}

}
