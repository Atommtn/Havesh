@using Havesh.Model.Model
@using HaveshApp.Admin.Dashboard.Personal.Widgets
@using System.Text.Json
@using Havesh.GrainInterfaces.Common
@using Havesh.Grains.Entity
@using Havesh.Grains.Manager
@using Havesh.Model.Data
@using HaveshApp.Admin.Dashboard.Widgets.Teacher
@using Newtonsoft.Json
@using System.Collections.Concurrent
@using DNTPersianUtils.Core
@using Havesh.Common
@using Havesh.GrainInterfaces.Entity
@using Havesh.GrainInterfaces.Manager
@using Havesh.OrleansClient
@using Microsoft.EntityFrameworkCore.ChangeTracking
@using Olive
@using Orleans.Runtime
@using Orleans.Streams
@inherits HaveshApp.Admin.DashboardManagement.WidgetResolvers.WidgetResolverBase
@implements IAsyncDisposable

<LargWidgetContainer Title="@($"فعالیت - {_activitiey?.ActivityTitle}")" WidgetSetting="WidgetSetting" ToRoles="...Supervisor" ViewRequired="_activitiey">
	<MudTable T="TimeTableSession" Items="_timeTableSessions">
		<ToolBarContent>
			<MudSpacer />
			<MudTextField @bind-Value="SearchText"
						  Adornment="Adornment.End"
						  AdornmentIcon="@Icons.Material.Filled.Search"
						  Clearable="true"
						  OnClearButtonClick="ClearSearchClick"
						  Placeholder="جستجو"
						  DebounceInterval="1000"
						  OnDebounceIntervalElapsed="SearchList" />
		</ToolBarContent>
		<HeaderContent>
			<MudTh>کلاس</MudTh>
			<MudTh>معلم</MudTh>
			<MudTh>جلسه</MudTh>
			<MudTh>@_activitiey?.ActivityTitle</MudTh>
		</HeaderContent>
		<RowTemplate>
			<MudTd>
				<MudChip Label="true" Color="@Color.Primary" OnClick="()=>ActivityChipClick(context)">
					@context.ClassRoom.ClassRoomName
				</MudChip>
			</MudTd>
			<MudTd>
				<MudText Typo="Typo.body1" Color="Color.Warning">
					@Teacher(context)
				</MudText>
			</MudTd>
			<MudTd>
				<MudChip Label="true" Size="Size.Small" Color="Color.Surface" Variant="Variant.Outlined">
					جلسه @context.SessionNumber
				</MudChip>

				@Level(context)

				<MudChip Label="true" Size="Size.Small" Variant="Variant.Outlined">
					@context.SessionStatus
				</MudChip>

				@OtherActivities(context)

			</MudTd>
			<MudTd>
				@{
					var items = GetOptions(context.Tag)?.ToArray();
					@if (items is not null)
					{
						<MudChip Size="Size.Large" OnClick="() => ActivityChipClick(context)">
							<MudTooltip Color="Color.Dark" Arrow="true">
								<TooltipContent>
									@*@{
										var timeTableGrain = ClusterCLient.GetGrain<ITimeTableGrain>(context.TimeTableFk);
										InvokeAsync(async () =>
										{
											var students = await timeTableGrain.GetStudents();
											var excludedStudents = context.TimeTable.Students?
												.Where(z =>
													items.SelectMany(x => x)
														.Count(a => a.Student.Id == z.Id) == 0)
												.ToArray();

										});
									}
									@if (excludedStudents is { Length: > 0 })
									{
										<MudText Typo="Typo.body1">نامشخص :</MudText>
										<MudList Dense="true">
											@foreach (var stu in excludedStudents)
											{
												<MudListItem Dense="true" Value="@stu.FullName">@stu.FullName</MudListItem>
											}
										</MudList>
									}*@
								</TooltipContent>
								<ChildContent>
									<MudChip Label="true" Color="Color.Dark" Size="Size.Small" Class="mx-2">
										<MudText Typo="Typo.body1">@items.Sum(x => x.Count()) از @context.TimeTable.Students?.Count() </MudText>
									</MudChip>
								</ChildContent>
							</MudTooltip>

							@foreach (var itm in items
								.OrderBy(x => x.Key.ActivityValue))
							{
								<MudTooltip Color="@GetButtonColor(itm.Key)" Arrow="true">
									<TooltipContent>
										<MudText Typo="Typo.body1">@itm.Key.ActivityValueOption.Title :</MudText>
										<MudList Dense="true">
											@foreach (var stu in itm)
											{
												<MudListItem Dense="true" Value="stu.Student.FullName">@stu.Student.FullName</MudListItem>
											}
										</MudList>
									</TooltipContent>
									<ChildContent>
										<MudChip Size="Size.Medium" 
										         Icon="@(itm.Key.ActivityValueOption.Icon ?? Icons.Material.Filled.Circle)" Color="@GetButtonColor(itm.Key)" Class="pulsing">
											<MudText Typo="Typo.body2">@itm.Count()</MudText>
											<MudChip Label="true" Size="Size.Small">
												@itm.Key.ActivityValueOption.Title
											</MudChip>

										</MudChip>
									</ChildContent>
								</MudTooltip>
							}


						</MudChip>

					}
				}
			</MudTd>
		</RowTemplate>
	</MudTable>
</LargWidgetContainer>

@code {
	private RenderFragment Level(TimeTableSession context) => __builder =>
	{
		<MudChip Size="Size.Small" Label="true" Variant="Variant.Outlined">
			@context.TimeTable.Level.LevelName
		</MudChip>
	};


	private RenderFragment OtherActivities(TimeTableSession context) => __builder =>
	{
		if (context.Tag is List<StudentSessionActivity> { Count: > 0 } lst &&
		    _activitiey != null)
		{
			var ls = lst
				.Where(x => x.ActivityFk != _activitiey.Id)
				.GroupBy(x => x,
					new ValueComparer<StudentSessionActivity>(
						(x, y) =>
							(x != null && y != null) &&
							x.Activity.Id == y.Activity.Id,
						option => option.Activity.Id.GetHashCode()));

			foreach (var sag in ls)
			{
				<MudBadge Content="sag.Count()" Color="Color.Warning" Overlap="true" Bordered="true">
					<MudChip Label="true" Color="Color.Info" Size="Size.Small" OnClick="()=>ActivityChipClick(context,sag.Key.Activity)">
						@sag.Key.Activity.ActivityTitle
					</MudChip>
				</MudBadge>
			}
		}
	};

	private RenderFragment Teacher(TimeTableSession context) =>
		__builder =>
		{
			if (context.TimeTable.TeacherId == context.TeacherFk)
			{
				<MudChip Size="Size.Large" Color="Color.Tertiary">@context.Teacher.FullName</MudChip>
				return;
			}
			<MudChip Size="Size.Small">
				<MudChip Size="Size.Large" Color="Color.Tertiary">@context.Teacher.FullName</MudChip>
				<MudChip Color="Color.Dark" Label="true">جایگزین</MudChip>
				<MudChip Size="Size.Small" Color="Color.Surface" Variant="Variant.Outlined">@context.TimeTable.Teacher.FullName</MudChip>
			</MudChip>
		};

}


