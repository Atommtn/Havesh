@using Havesh.Model.Model
@using HaveshApp.Admin.Dashboard.Personal.Widgets
@using System.Text.Json
@using Havesh.GrainInterfaces.Common
@using Havesh.Grains.Entity
@using Havesh.Grains.Manager
@using Havesh.Model.Data
@using HaveshApp.Admin.Dashboard.Widgets.Teacher
@using Newtonsoft.Json
@using System.Collections.Concurrent
@using Olive
@inherits HaveshApp.Admin.DashboardManagement.WidgetResolvers.WidgetResolverBase
@implements IDisposable


<LargWidgetContainer Title="@($"فعالیت  - {_activitiey?.ActivityTitle}")" WidgetSetting="WidgetSetting" ToRoles="...Supervisor" ViewRequired="_activitiey">

	<MudTable T="TimeTableSession" Items="_timeTableSessions">
		<HeaderContent>
			<MudTh>کلاس</MudTh>
			<MudTh>معلم</MudTh>
			<MudTh>جلسه</MudTh>
			<MudTh>فعالیت</MudTh>
		</HeaderContent>
		<RowTemplate>
			<MudTd>
				<MudChip Label="true">
					@context.ClassRoom.ClassRoomName
				</MudChip>
			</MudTd>
			<MudTd>
				<MudText Typo="Typo.body1" Color="Color.Warning">
					@context.Teacher.FullName
				</MudText>
			</MudTd>
			<MudTd>
				<MudChip Label="true" Size="Size.Small" Color="Color.Success">
					@context.SessionNumber -
					@context.SessionStatus
				</MudChip>
			</MudTd>
			<MudTd>
				@foreach (var itm in GetReport(context.Tag))
				{
					<MudChip Size="Size.Small"> @itm </MudChip>
				}
				
			</MudTd>
		</RowTemplate>
	</MudTable>
</LargWidgetContainer>

@code {
	[Inject] SupervisorWidgetsService SupervisorWidgetsService { get; set; } = null!;
	[Inject] IClusterClient ClusterCLient { get; set; }
	List<TimeTableSession>? _timeTableSessions;
	SessionActivity? _activitiey;


	protected override async Task OnInitializedAsync()
	{
		SupervisorWidgetsService.OnStudentActivityPerformed += SupervisorWidgetsServiceOnStudentActivityPerformed;

		_timeTableSessions = ((await SupervisorWidgetsService.GetTimeTableSessions())!).ToList();


		var managerGrain = ClusterCLient.GetGrain<IStudentSessionActivityManagerGrain>(Guid.Empty);
		_activitiey = await managerGrain.GetDefaultSesionActivity();

		var sessionManagerGrain = ClusterCLient.GetGrain<ITimeTableSessionManagerGrain>(Guid.Empty);
		_timeTableSessions.ForEach(async tts =>
		{
			var sessionActivityValueOptions = await sessionManagerGrain.GetSessionActivityPerforms(tts.Id);

			tts.Tag = (sessionActivityValueOptions ?? Array.Empty<SessionActivityValueOption>()).ToList();
		});

		await base.OnInitializedAsync();
	}

	private async Task SupervisorWidgetsServiceOnStudentActivityPerformed(StudentSessionActivity arg)
	{

		if (_activitiey != null && 
		    _timeTableSessions != null &&
		    arg.ActivityFk == _activitiey.Id
		    )
		{
			var activityValueOptionGrain = ClusterCLient.GetGrain<IHaveshGrain<SessionActivityValueOption>>(arg.ActivityValueOptionFk);
			var sessionActivityValueOption = await activityValueOptionGrain.Get();
			var timeTableSession = Enumerable.FirstOrDefault(_timeTableSessions, x => x.Id == arg.TimeTableSessionFk);
			if (timeTableSession?.Tag is List<SessionActivityValueOption> lst)
			{
				if (sessionActivityValueOption != null)
				{
					lst.Add(sessionActivityValueOption);
				}
			}
			else
			{
				if (timeTableSession != null && sessionActivityValueOption != null)
					timeTableSession.Tag = new List<SessionActivityValueOption> 
						{ sessionActivityValueOption };
			}
		}
		await InvokeAsync(StateHasChanged);

	}

	public void Dispose()
	{
		SupervisorWidgetsService.OnStudentActivityPerformed -= SupervisorWidgetsServiceOnStudentActivityPerformed;
	}


	private IEnumerable<string> GetReport(object? tag)
	{
		string[] list = { };
		if (tag is List<SessionActivityValueOption> {Count: > 0 } lst)
		{
			list = lst
				.GroupBy(x => x.Value)
				.Select(x => $"{x.Key} - {x.Count()}")
				.ToArray();
		}
		return list;
	}

}