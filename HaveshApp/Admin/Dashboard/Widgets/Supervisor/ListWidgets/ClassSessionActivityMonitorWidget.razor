@using Havesh.Model.Model
@using HaveshApp.Admin.Dashboard.Personal.Widgets
@using System.Text.Json
@using Havesh.GrainInterfaces.Common
@using Havesh.Grains.Entity
@using Havesh.Grains.Manager
@using Havesh.Model.Data
@using HaveshApp.Admin.Dashboard.Widgets.Teacher
@using Newtonsoft.Json
@using System.Collections.Concurrent
@using Olive
@inherits HaveshApp.Admin.DashboardManagement.WidgetResolvers.WidgetResolverBase
@implements IDisposable

<LargWidgetContainer Title="@($"فعالیت  - {_activitiey?.ActivityTitle}")" WidgetSetting="WidgetSetting" ToRoles="...Supervisor" ViewRequired="_activitiey">

	<MudTable T="TimeTableSession" Items="_timeTableSessions">
		<HeaderContent>
			<MudTh>کلاس</MudTh>
			<MudTh>معلم</MudTh>
			<MudTh>جلسه</MudTh>
			<MudTh>فعالیت</MudTh>
		</HeaderContent>
		<RowTemplate>
			<MudTd>
				<MudChip Label="true">
					@context.ClassRoom.ClassRoomName
				</MudChip>
			</MudTd>
			<MudTd>
				<MudText Typo="Typo.body1" Color="Color.Warning">
					@context.Teacher.FullName
				</MudText>
			</MudTd>
			<MudTd>
				<MudChip Label="true" Size="Size.Small" Color="Color.Success">
					@context.SessionNumber -
					@context.SessionStatus
				</MudChip>
			</MudTd>
			<MudTd>
				@foreach (var itm in GetReport(context.Tag))
				{
					<MudChip Size="Size.Small"> @itm </MudChip>
				}

			</MudTd>
		</RowTemplate>
	</MudTable>
</LargWidgetContainer>

@code {
	[Inject] SupervisorWidgetsService SupervisorWidgetsService { get; set; } = null!;
	[Inject] IClusterClient ClusterCLient { get; set; }
	List<TimeTableSession>? _timeTableSessions;
	SessionActivity? _activitiey;


	protected override async Task OnInitializedAsync()
	{

		Console.WriteLine("---------------------------------");
		Console.WriteLine("---------------------------------");
		Console.WriteLine("---------------------------------");
		Console.WriteLine("---------------------------------> SupervisorWidgetsService.OnStudentActivityPerformedEvent ");
		Console.WriteLine("---------------------------------");
		Console.WriteLine("---------------------------------");
		Console.WriteLine("---------------------------------");
		
		await SupervisorWidgetsService.InitSubscribeToStudentActivityPerformAsync();

		SupervisorWidgetsService.OnStudentActivityPerformedEvent += SupervisorWidgetsServiceOnStudentActivityPerformedEvent;

		_timeTableSessions = ((await SupervisorWidgetsService.GetTimeTableSessions())!).ToList();


		var managerGrain = ClusterCLient.GetGrain<IStudentSessionActivityManagerGrain>(Guid.Empty);
		_activitiey = await managerGrain.GetDefaultSesionActivity();

		var sessionManagerGrain = ClusterCLient.GetGrain<ITimeTableSessionManagerGrain>(Guid.Empty);
		_timeTableSessions.ForEach(async tts =>
		{
			var sessionActivityValueOptions = await sessionManagerGrain.GetSessionActivitiesPerformed(tts.Id);

			var activityValueOptions = (sessionActivityValueOptions ?? Array.Empty<SessionActivityValueOption>()).ToList();
			if (activityValueOptions.Count > 0)
				Console.WriteLine();

			tts.Tag = activityValueOptions;
		});

		await base.OnInitializedAsync();
	}



	private async Task SupervisorWidgetsServiceOnStudentActivityPerformedEvent(StudentSessionActivity arg)
	{
		Console.Beep(1000, 500);

		if (_activitiey != null &&
			_timeTableSessions != null &&
			arg.ActivityFk == _activitiey.Id
			)
		{
			var timeTableSession = _timeTableSessions.FirstOrDefault(x => x.Id == arg.TimeTableSessionFk);
			var sessionManagerGrain = ClusterCLient.GetGrain<ITimeTableSessionManagerGrain>(Guid.Empty);
			var sessionActivityValueOptions = await sessionManagerGrain.GetSessionActivitiesPerformed(timeTableSession.Id);

			var activityValueOptions = (sessionActivityValueOptions ?? Array.Empty<SessionActivityValueOption>())
				.ToList();
			
			if (activityValueOptions.Count > 0)
				Console.WriteLine();

			timeTableSession.Tag = activityValueOptions;
		}
		await InvokeAsync(StateHasChanged);

	}

	public void Dispose()
	{
		SupervisorWidgetsService.OnStudentActivityPerformedEvent -= SupervisorWidgetsServiceOnStudentActivityPerformedEvent;
	}


	private IEnumerable<string> GetReport(object? tag)
	{
		string[] list = { };
		if (tag is List<SessionActivityValueOption> { Count: > 0 } lst)
		{
			list = lst
				.GroupBy(x => x.Value)
				.Select(x => $"{x.Key} - {x.Count()}")
				.ToArray();
		}
		return list;
	}

}