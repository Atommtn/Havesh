@using Havesh.Model.Model
@using HaveshApp.Admin.Dashboard.Personal.Widgets
@using HaveshApp.Admin.Dashboard.Widgets.Teacher
@inherits HaveshApp.Admin.DashboardManagement.WidgetResolvers.WidgetResolverBase

<LargWidgetContainer WidgetSetting="WidgetSetting" ViewRequired="_intervals" ToRoles="...Supervisor">

	<MudTable T="ShokouhPardisInterval" Items="_intervals">
		<HeaderContent>
			<MudTh>سانس</MudTh>
			<MudTh>ساعت آغاز</MudTh>
			<MudTh>ساعت خاتمه</MudTh>
		</HeaderContent>
		<RowTemplate>
			<MudTd>@context.Title</MudTd>
			<MudTd>@context.StartTime</MudTd>
			<MudTd>@context.EndTime</MudTd>
		</RowTemplate>
	</MudTable>
</LargWidgetContainer>

@code {
	private List<ShokouhPardisInterval>? _intervals;

	[Inject] SupervisorWidgetsService SupervisorWidgetsService { get; set; }

	protected override void OnInitialized()
	{
		var term = _dataProvider.GetTermsInRangeToday();
		_intervals = _dataProvider.GetIntervals(term);
		base.OnInitialized();
	}

}
