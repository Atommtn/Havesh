@using Havesh.Model.Model
@using Havesh.Grains.Manager
@using Havesh.Common
@using DNTPersianUtils.Core
@using Havesh.GrainInterfaces.Entity
@using Havesh.Model.Data
@using HaveshApp.Admin.Dashboard.Widgets.Supervisor.Dialog
@using Microsoft.EntityFrameworkCore
@using System.Reflection
<MudDialog>
	<DialogContent>
		<MudTable Items="Sessions">
			<HeaderContent>
				<MudTh>جلسه</MudTh>
				<MudTh>تاریخ</MudTh>
				<MudTh>وضعیت</MudTh>
				<MudTh></MudTh>
			</HeaderContent>
			<RowTemplate>
				<MudTd>@context.SessionNumber</MudTd>
				<MudTd>
					<MudChip>
						@context.SessionDate.ToPersianDateTextify()
					</MudChip>
				</MudTd>
				<MudTd>
					@SessionStatusSelector(context)
					
				</MudTd>
				<MudTd>					
					@ActivityList(context)
				</MudTd>
			</RowTemplate>
		</MudTable>
	</DialogContent>
	<DialogActions>
		<MudButton Variant="Variant.Text" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Close" OnClick="CloseDialogClick">
			Close
		</MudButton>
		<MudButton Variant="Variant.Text" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Close" OnClick="SaveSessionsChangeClick">
			Save
		</MudButton>

	</DialogActions>
</MudDialog>
@code {

	[Parameter] public ShokouhPardisTimeTable TimeTable { get; set; }

	public IEnumerable<TimeTableSession>? Sessions { get; set; }

	[CascadingParameter] MudDialogInstance DialogInstance { get; set; }

	[Inject] public IClusterClient ClusterClient { get; set; }
	
	IEnumerable<StudentSessionActivity>? _summary;
	IEnumerable<SessionActivity>? _sesionActivities;
	protected override async Task OnInitializedAsync()
	{
		var timeTableSessionManagerGrain = ClusterClient.GetGrain<ITimeTableSessionManagerGrain>(HaveshConstants.GeneralKey);
		Sessions = await timeTableSessionManagerGrain.GetTimeTableSessions(TimeTable.Id);

		_summary = GetStudentSessionActivities(TimeTable.Id);
		var managerGrain = ClusterClient.GetGrain<IStudentSessionActivityManagerGrain>(Guid.Empty);
		_sesionActivities = await managerGrain.GetGeneralSesionActivities();

		await base.OnInitializedAsync();
	}

	private void CloseDialogClick()
	{
		DialogInstance.Cancel();
	}


	List<StudentSessionActivity> GetStudentSessionActivities(int timeTableFk)
	{
		return _dataProvider.GetTimetableStudentsSessionActivities(timeTableFk);
	}

	private RenderFragment ActivityList(TimeTableSession tts) => __builder =>
	{
		var sx = _summary?
			.Where(x => x.TimeTableSessionFk == tts.Id)
			.GroupBy(x => x.Activity)
		;

		foreach (var sum in sx!)
		{
			<MudChip Color="@(sum.Key.IconColor ?? Color.Default )" OnClick="()=>OpenRollCallItem(sum.Key , tts)" >
				@sum.Key.ActivityTitle - @sum.Count()
			</MudChip>
		}
		
		<MudMenu>
			<ActivatorContent>
				یا یک فعالیت دیگر انتخاب کنید
			</ActivatorContent>
			<ChildContent>
				@foreach(var sa in _sesionActivities)
				{
					<MudMenuItem OnClick="() => OpenRollCallItem(sa, tts)">
						@sa.ActivityTitle
					</MudMenuItem>
				}
			</ChildContent>
		</MudMenu>

	};


	private async Task OpenRollCallItem(SessionActivity sessionActivity, TimeTableSession timeTableSession)
	{
		var dialogReference = await _dialogService.ShowAsync<TimeTableSessionArchiveStudentActivityDialog>("Session Activity " + sessionActivity.ActivityTitle ,
			new DialogParameters<TimeTableSessionArchiveStudentActivityDialog>
			{
				{ x=>x.SessionActivityItem, sessionActivity },
				{ x=>x.TimeTableSessionItem, timeTableSession },
			},
			new DialogOptions()
			{
				FullWidth = true
			});
		var result = await dialogReference.Result;
		_summary = GetStudentSessionActivities(TimeTable.Id);
		StateHasChanged();
	}

	string? sessionStatus = null;

	private RenderFragment SessionStatusSelector(TimeTableSession context) => __builder =>
	{
		<MudSelect @bind-Value="context.SessionStatus">
			@foreach (var status in typeof(SessionStatuses).GetFields(BindingFlags.Public | BindingFlags.Static))
			{
				<MudSelectItem Value="@(status.GetValue(status)?.ToString())">
					@status.GetValue(status)?.ToString()
				</MudSelectItem>
			}
		</MudSelect>
	};

	private void SaveSessionsChangeClick()
	{
		_dataProvider.SaveAll();
		CloseDialogClick();
	}
}



