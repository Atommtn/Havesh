@using Havesh.Model.Model
@using HaveshApp.Admin.Dashboard.Personal.Widgets
@using System.Text.Json
@using Havesh.Model.Data
@using HaveshApp.Admin.Dashboard.Widgets.Teacher
@using Newtonsoft.Json
@inherits HaveshApp.Admin.DashboardManagement.WidgetResolvers.WidgetResolverBase
@implements IDisposable
<LargWidgetContainer WidgetSetting="WidgetSetting" ViewRequired="_timeTables" ToRoles="...Supervisor">

	<MudTable T="ShokouhPardisTimeTable" Items="_timeTables">
		<HeaderContent>
			<MudTh>کلاس</MudTh>
			<MudTh>معلم</MudTh>
			<MudTh>جلسه</MudTh>
			<MudTh>حاضرین</MudTh>
			<MudTh>غایبین</MudTh>
		</HeaderContent>
		<RowTemplate>
			<MudTd>
				<MudChip Label="true">
					@context.ClassRoom.ClassRoomName
				</MudChip>
			</MudTd>
			<MudTd>
				<MudText Typo="Typo.body1" Color="Color.Warning">
					@context.Teacher.FullName
				</MudText>
			</MudTd>
			<MudTd>
				<MudChip Label="true" Size="Size.Small" Color="Color.Success">
					@context.Sessions.FirstOrDefault(x => x.SessionDate >= DateTime.Today)?.SessionNumber -
					@context.Sessions.FirstOrDefault(x => x.SessionDate >= DateTime.Today)?.SessionStatus
				</MudChip>
			</MudTd>
			<MudTd>
				@if (Absents.TryGetValue(context.Id, out var ac))
				{
					@ac
				}
			</MudTd>
			<MudTd>
				@if (Presents.TryGetValue(context.Id, out var pc))
				{
					@pc
				}
			</MudTd>
		</RowTemplate>
	</MudTable>
</LargWidgetContainer>

@code {
	Dictionary<int, int> Absents = new Dictionary<int, int>();
	Dictionary<int, int> Presents = new Dictionary<int, int>();
	[Inject]  SupervisorWidgetsService SupervisorWidgetsService { get; set; } = null!;

	IEnumerable<ShokouhPardisTimeTable>? _timeTables;
	protected override async Task OnInitializedAsync()
	{
		await SupervisorWidgetsService.InitSubscribeToStudentActivityPerformAsync();
		SupervisorWidgetsService.OnStudentActivityPerformedEvent +=	SupervisorWidgetsServiceOnOnStudentActivityPerformedEvent;
		_timeTables = await SupervisorWidgetsService.GetIntervalTimeTables();
		await base.OnInitializedAsync();
	}

	private Task SupervisorWidgetsServiceOnOnStudentActivityPerformedEvent(StudentSessionActivity arg)
	{
		throw new NotImplementedException();
	}

	public void Dispose()
	{
		SupervisorWidgetsService.OnStudentActivityPerformedEvent -= SupervisorWidgetsServiceOnOnStudentActivityPerformedEvent;
	}

}