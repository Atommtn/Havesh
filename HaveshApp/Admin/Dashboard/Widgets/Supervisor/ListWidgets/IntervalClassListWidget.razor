@using Havesh.Model.Model
@using HaveshApp.Admin.Dashboard.Personal.Widgets
@using System.Text.Json
@using Havesh.Model.Data
@using HaveshApp.Admin.Dashboard.Widgets.Teacher
@using Newtonsoft.Json
@inherits HaveshApp.Admin.DashboardManagement.WidgetResolvers.WidgetResolverBase
<LargWidgetContainer WidgetSetting="WidgetSetting" ViewRequired="_timeTables" ToRoles="...Supervisor">

	<MudTable T="ShokouhPardisTimeTable" Items="_timeTables">
		<HeaderContent>
			<MudTh>کلاس</MudTh>
			<MudTh>معلم</MudTh>
			<MudTh>جلسه</MudTh>
			<MudTh></MudTh>
		</HeaderContent>
		<RowTemplate>
			<MudTd>
				<MudChip Label="true">
					@context.ClassRoom.ClassRoomName
				</MudChip>
			</MudTd>
			<MudTd>
				<MudText Typo="Typo.body1" Color="Color.Warning">
					@context.Teacher.FullName
				</MudText>
			</MudTd>
			<MudTd>
				<MudChip Label="true" Size="Size.Small" Color="Color.Success">
					@context.Sessions.FirstOrDefault(x => x.SessionDate >= DateTime.Today)?.SessionNumber -
					@context.Sessions.FirstOrDefault(x => x.SessionDate >= DateTime.Today)?.SessionStatus
				</MudChip>
			</MudTd>
		</RowTemplate>
	</MudTable>
</LargWidgetContainer>

@code {
	[Inject]  SupervisorWidgetsService SupervisorWidgetsService { get; set; } = null!;

	IEnumerable<ShokouhPardisTimeTable>? _timeTables;
	protected override async Task OnInitializedAsync()
	{
		_timeTables = await SupervisorWidgetsService.GetIntervalTimeTables();
		await base.OnInitializedAsync();
	}

}