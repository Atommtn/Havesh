@using HaveshApp.Classes
@using Havesh.Domain
<MudSelect T="string" @bind-Value="Value" SelectedValuesChanged="SelectedChange" Label="بابت" Dense="true" TransformOrigin="Origin.TopCenter">
  
    <MudSelectItem Value="@FeeForStatuses.TuitionAmount"/>
    <MudSelectItem Value="@FeeForStatuses.Book"/>
    <MudSelectItem Value="@FeeForStatuses.PrivateClass"/>
    <MudSelectItem Value="@FeeForStatuses.Final"/>
    <MudSelectItem Value="@FeeForStatuses.Placement"/>
    <MudSelectItem Value="@FeeForStatuses.Refund"/>
</MudSelect>
@code {

    [Parameter]
    public string Value { get; set; }

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    private async Task SelectedChange()
    {
            await ValueChanged.InvokeAsync(Value);
        
    }


    private string _value;
}
