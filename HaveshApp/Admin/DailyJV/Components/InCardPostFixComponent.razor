    <MudSelectItem Value="@CardNumber.CN5683" />
    <MudSelectItem Value="@CardNumber.CN8304" />
    <MudSelectItem Value="@CardNumber.CN9335" />
    <MudSelectItem Value="@CardNumber.CN3586" />
    <MudSelectItem Value="@CardNumber.CN1602" />
    <MudSelectItem Value="@CardNumber.CN4601" />
    <MudSelectItem Value="@CardNumber.CN1670" />
