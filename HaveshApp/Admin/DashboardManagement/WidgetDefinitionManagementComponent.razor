@using Havesh.Model.Data.Dashboard

<MudTable Items="_widgets">
    <ToolBarContent>
        <MudButton Color="Color.Success" StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Text" OnClick="AddNewWidgetClick">
            Add New Widget
        </MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Id</MudTh>
        <MudTh>Icon</MudTh>
        <MudTh>Title</MudTh>
        <MudTh>Break Points</MudTh>
        <MudTh>Type</MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Id</MudTd>
        <MudTd>
            <MudIcon Icon="@context.Icon" Color="@context.IconColor" Size="Size.Medium"></MudIcon>
        </MudTd>
        <MudTd>@context.Title</MudTd>
        <MudTd>@context.BreakPoints</MudTd>
        <MudTd>
            @context.Type
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Variant="Variant.Text" OnClick="()=>EditWidgetDefinitionClick(context)" />
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<Widget>? _widgets;
    protected override void OnInitialized()
    {
        UpdateWidgetsList();

        base.OnInitialized();
    }

    private void UpdateWidgetsList()
    {
        _widgets = _dashboardProvider.GetWidgets();
    }

    private async Task AddNewWidgetClick()
    {
        var newWidget = new Widget();
        await EditWidget(newWidget);
    }

    private async Task EditWidget(Widget widget)
    {
        var dialogReference = await _dialogService.ShowAsync<WidgetDialog>($"{(widget.Id > 0 ? "Edit" : "New")} Widget",
            new DialogParameters()
            {
                ["Widget"] = widget
            });
        var result = await dialogReference.Result;
        if (!result.Canceled)
        {
            if (result.Data is Widget widgetResult)
            {
                _dashboardProvider.UpdateWidget(widgetResult);
                UpdateWidgetsList();
            }
        }
    }

    [CascadingParameter]
    public MudDialogInstance DialogInstance { get; set; }

    private void AddWidgetToDashboardTemplateClick(Widget context)
    {
        DialogInstance.Close(context);
    }

    private async Task EditWidgetDefinitionClick(Widget context)
    {
        await EditWidget(context);
    }

}
