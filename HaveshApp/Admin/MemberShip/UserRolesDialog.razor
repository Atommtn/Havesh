@using ShokouhApp.Services
@using ShokouhApp.Admin.MemberShip.Model
<MudDialog>
    <DialogContent>
        <MudTable Items="_roles" MultiSelection="true" @bind-SelectedItems="_selectedRoles"> </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Success" StartIcon="@Icons.Filled.Save" Variant="Variant.Text" OnClick="SaveClick">
            Save
        </MudButton>

        <MudButton Color="Color.Warning" StartIcon="@Icons.Filled.Close" Variant="Variant.Text" OnClick="CloseDialogClick">
            Close
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public User User { get; set; }

    [CascadingParameter]
    public MudDialogInstance DialogInstance { get; set; }

    [Inject]
    DataProviderService ProviderService { get; set; }

    protected override void OnInitialized()
    {
        _roles = ProviderService.GetRoles();
        _selectedRoles = User.Roles.ToHashSet();
        base.OnInitialized();
    }

    private void CloseDialogClick()
    {
        DialogInstance.Close();
    }

    private List<Role> _roles;
    private HashSet<Role> _selectedRoles;

    private void SaveClick()
    {
        User.Roles.Clear();
        User.Roles.AddRange(_selectedRoles);
        ProviderService.SaveUser(User);
        DialogInstance.Close();
    }

}
