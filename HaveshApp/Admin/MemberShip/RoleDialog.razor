@using Havesh.Model.Model
<h3>RoleDialog</h3>
<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem md="6">
                <MudTextField @bind-Value="Role.Name" Label="Role Name"/>
            </MudItem>
            <MudItem md="6">

            </MudItem>
        </MudGrid>

    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Success" StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Text" OnClick="SaveClick">
            Save
        </MudButton>

        <MudButton Color="Color.Warning" StartIcon="@Icons.Material.Filled.Close" Variant="Variant.Text" OnClick="CloseDialogClick">
            Close
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Inject]
    DataProviderService ProviderService { get; set; }

    [CascadingParameter]
    public MudDialogInstance DialogInstance { get; set; }

    [Parameter]
    public Role Role { get; set; }

    private void CloseDialogClick()
    {
        DialogInstance.Close();

    }

    private void SaveClick()
    {
        ProviderService.SaveRole(Role);
        DialogInstance.Close();
    }

}
