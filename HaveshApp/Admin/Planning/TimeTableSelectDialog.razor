@using Havesh.Model.Model
<MtnDialog>
    <ChildComponent>
        <MudTable @ref="table"
                  Breakpoint="Breakpoint.None"
                  Height="450px"
                  GroupBy="@_groupDefinition"
                  Dense="true"
                  ServerData="ServerReload"
                  Loading="@DataLoading"
                  RowsPerPage="200">

            <ToolBarContent>
                <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Style="width: 100%">


                    <MudTextField @bind-Value="SearchText"
                                  Label="جستجو"
                                  Placeholder="می توانید بر اساس هر موضوعی جستجو کنید"
                                  DebounceInterval="1000"
                                  OnDebounceIntervalElapsed="FilterData"
                                  AdornmentIcon="@Icons.Filled.Search"
                                  Adornment="Adornment.Start"
                                  Clearable="true" />
                </MudStack>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>مشخصات</MudTh>

                <MudTh></MudTh>
            </HeaderContent>
            <GroupHeaderTemplate>
                <MudTh Class="mud-table-cell-custom-group" colspan="9">
                    <MudChip Label="false" Icon="@Icons.Filled.PersonPin">
                        @($"{context.GroupName}: {context.Key}")
                    </MudChip>
                    <MudChip Label="true" Size="Size.Small" Icon="@Icons.Filled.DeveloperBoard">
                        @context.Items.Count() کلاس
                    </MudChip>
                    <MudChip Label="true" Size="Size.Small" Icon="@Icons.Filled.People">
                        @context.Items.Select(x => _timeTableStudentsCount.TryGetValue(x.Id, out var count) ? count : 0).Sum() زبان آموز
                    </MudChip>
                </MudTh>
                <MudTh></MudTh>
            </GroupHeaderTemplate>
            <RowTemplate>
                <MudTd>
                    <TimeTableItemComponent ShowRecordId="true" TimeTable="context"></TimeTableItemComponent>
                </MudTd>



                <MudTd>
                    <MudIconButton Icon="@Icons.Filled.MoveToInbox" Color="Color.Success" Variant="Variant.Filled" OnClick="() => MoveDialogClick(context)" />

                </MudTd>

            </RowTemplate>
            <GroupFooterTemplate>
                <MudTh Class="mud-table-cell-custom-group mud-table-cell-custom-group-footer" colspan="3">
                    جمع کلاس ها: @context.Items.Count()
                </MudTh>
                <MudTh Class="mud-table-cell-custom-group mud-table-cell-custom-group-footer" colspan="3">
                    جمع زبان آموزان: @context.Items.Select(x => _timeTableStudentsCount.TryGetValue(x.Id,out var count) ? count : 0).Sum()
                </MudTh>
            </GroupFooterTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new []{200,300,400}" />
            </PagerContent>
        </MudTable>
    </ChildComponent>
    <DialogAction>
        <MudButton Color="Color.Warning" StartIcon="@Icons.Filled.Close" Variant="Variant.Text" OnClick="CancleDialogClick">
            انصراف
        </MudButton>
    </DialogAction>
</MtnDialog>

@code {
    [Parameter]
    public ShokouhPardisTimeTable TimeTable { get; set; }
    [Parameter]
    public ShokouhPardisStudentClass Student { get; set; }

    [Inject] ISnackbar Snackbar { get; set; }

    [CascadingParameter]
    MudDialogInstance DialogInstance { get; set; }

    [Inject]
    public IDialogService DialogService { get; set; }

    [Inject] NavigationManager NavigationManager { get; set; }
    bool DataLoading;
    MudTable<ShokouhPardisTimeTable>? table;

    bool initComplete = false;
    public ShokouhPardisTermClass Term { get; set; }
    string? SearchText { get; set; }
    Dictionary<int, int> _timeTableStudentsCount;
    private async Task MoveDialogClick(ShokouhPardisTimeTable selectTimeTable)
    {
        if (selectTimeTable == TimeTable)
        {
            Snackbar.Add("این همان کلاس قبلی زبان آموز می باشد", Severity.Error);
        }
        else
        {
            var move = await DialogService.ShowMessageBox("انتقال زبان آموز",
                (MarkupString)$"آیا از انتقال زبان آموز <br /><br /> <b style='Color:Red'> {Student.FullName} </b>  به کلاس <br /> <br />{selectTimeTable.Teacher.FullName} <br /> {selectTimeTable.Level.LevelName} <br /><br /> مطمئن هستید؟", "بله", "خیر");
            if (move is true)
            {
                DialogInstance.Close(selectTimeTable);
            }

        }
    }

    private void CancleDialogClick()
    {
        DialogInstance.Cancel();
    }

    readonly TableGroupDefinition<ShokouhPardisTimeTable> _groupDefinition = new()
        {
            GroupName = "مدرس",
            Indentation = false,
            Expandable = true,
            IsInitiallyExpanded = false,
            Selector = (e) => e.Teacher
        };
    void Init()
    {
        if (initComplete)
            return;
        DataLoading = true;
        StateHasChanged();
        Term = _dataProvider.GetTermsInRangeToday();
        initComplete = true;
        StateHasChanged();
    }
    async Task<TableData<ShokouhPardisTimeTable>> ServerReload(TableState state)
    {
        Init();

        DataLoading = true;
        StateHasChanged();
        _timeTableStudentsCount = _dataProvider.GetTimeTableStudentsCount(Term);
        var total = _dataProvider.GetTotalTimeTablesCount(Term.Id, SearchText, false);
        var timeTables = _dataProvider.GetTimeTables(state.Page, state.PageSize, SearchText, Term, false).ToList();
        timeTables.ForEach(x =>
        {
            if (_timeTableStudentsCount.TryGetValue(x.Id, out var zz))
                x.StudentsCount = zz;
        });
        DataLoading = false;

        return new TableData<ShokouhPardisTimeTable>
            {
                TotalItems = total,
                Items = timeTables
            };

    }

    Task FilterData()
    {
        return table?.ReloadServerData()!;
    }


}
