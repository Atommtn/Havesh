@page "/TeacherTimeTable"
@using ShokouhApp.Admin.Planning.Components
@using ShokouhApp.Admin.Clone
@using Microsoft.AspNetCore.Components
@using Olive
@layout PersianPagesLayout

@attribute [Authorize]

<MudPaper Class="ma-3 pa-5">
    <TermSelectorComponent @bind-Term="Term"></TermSelectorComponent>
    <MudTable @ref="table"
              Breakpoint="Breakpoint.None"
              Height="450px"
              GroupBy="@_groupDefinition"
              Dense="true"
              ServerData="ServerReload"
              Loading="@DataLoading"
              RowsPerPage="200">

        <ToolBarContent>
            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Style="width: 100%">

                <MudButton Color="Color.Success" StartIcon="@Icons.Filled.Add" Variant="Variant.Text" OnClick="NewTimesheetClick">
                    تعریف برنامه کلاسی
                    </MudButton>
                <MudSwitch @bind-Checked="@isPrivate" Label="نمایش کلاس های خصوص" Color="Color.Primary"  />
                <MudSpacer />
                <MudTextField @bind-Value="SearchText"
                              Label="جستجو"
                              Placeholder="می توانید بر اساس هر موضوعی جستجو کنید"
                              DebounceInterval="1000"
                              OnDebounceIntervalElapsed="FilterData"
                              AdornmentIcon="@Icons.Filled.Search"
                              Adornment="Adornment.Start"
                              Clearable="true" />
            </MudStack>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>مشخصات</MudTh>
            @*
            <MudTh>Id</MudTh>
            <MudTh>Teacher</MudTh>
            <MudTh>Level</MudTh>
            <MudTh>Schedule</MudTh>
            <MudTh>Students</MudTh>*@

            <MudTh></MudTh>
        </HeaderContent>
        <GroupHeaderTemplate>
            <MudTh Class="mud-table-cell-custom-group" colspan="9">
                <MudChip Label="false" Icon="@Icons.Filled.PersonPin">
                    @($"{context.GroupName}: {context.Key}")
                </MudChip>
                <MudChip Label="true" Size="Size.Small" Icon="@Icons.Filled.DeveloperBoard">
                    @context.Items.Count() کلاس
                </MudChip>
                <MudChip Label="true" Size="Size.Small" Icon="@Icons.Filled.People">
                    @context.Items.Select(x => _timeTableStudentsCount.TryGetValue(x.TimeTableId, out var count) ? count : 0).Sum() زبان آموز
                </MudChip>
            </MudTh>
            <MudTh></MudTh>
        </GroupHeaderTemplate>
        <RowTemplate>
            <MudTd>
                <TimeTableItemComponent ShowRecordId="true" TimeTable="context"></TimeTableItemComponent>
            </MudTd>


            @* <MudTd>@context.Term.TermName</MudTd>
            <MudTd>@context.Teacher</MudTd>
            <MudTd>@context.Level.LevelName</MudTd>
            <MudTd>@context.Schedule.Title</MudTd>
            <MudTd>
            @if (_timeTableStudentsCount.TryGetValue(context.TimeTableId, out var count))
            {
            @count
            }
            </MudTd>*@

            <MudTd>
                <MudIconButton Icon="@Icons.Filled.InstallDesktop" Color="Color.Success" Variant="Variant.Filled" OnClick="() => AddStudentToClassClick(context)" />
                <MudIconButton Icon="@Icons.Filled.Edit" Color="Color.Info" Variant="Variant.Text" OnClick="() => EditButtonClick(context)" />
                <MudIconButton Icon="@Icons.Filled.Delete" Color="Color.Error" Variant="Variant.Text" OnClick="() => DeleteButtonClick(context)"/>
                <MudIconButton Icon="@Icons.Filled.ManageAccounts" Color="Color.Primary" Variant="Variant.Filled" OnClick="() => ManageSessionClick(context)"/>
            </MudTd>

        </RowTemplate>
        <GroupFooterTemplate>
            <MudTh Class="mud-table-cell-custom-group mud-table-cell-custom-group-footer" colspan="3">
                جمع کلاس ها: @context.Items.Count()
            </MudTh>
            <MudTh Class="mud-table-cell-custom-group mud-table-cell-custom-group-footer" colspan="3">
                جمع زبان آموزان: @context.Items.Select(x => _timeTableStudentsCount.TryGetValue(x.TimeTableId,out var count) ? count : 0).Sum()
            </MudTh>
        </GroupFooterTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new []{200,300,400}" />
        </PagerContent>
    </MudTable>

</MudPaper>

