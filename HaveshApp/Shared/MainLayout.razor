@using HaveshApp.Admin.Setting;
@using HaveshApp.Pages.Chat
@using HaveshApp.Pages.MessageBox
@using HaveshApp.Services
@using HaveshApp.Model
@using Olive
@using System.Security.Claims
@using HaveshApp.Admin.Authentication
@using HaveshApp.Classes
@inherits LayoutComponentBase



<PageTitle>Havesh App</PageTitle>

<MudThemeProvider IsDarkMode="true" />
<MudDialogProvider />
<MudSnackbarProvider />

<HubConnectorComponent />

<MudLayout>
	<MudAppBar Fixed="false" Elevation="1">
		<MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
		HAVESH Professional Academy Portal
		<MudSpacer />
		<AuthorizeView>
			<Authorized>

				<MudText Typo="Typo.caption" Color="Color.Default" Class="m-3">
					سلام @_userSession.Payload.Gender @_userSession.Payload.FirstName @_userSession.Payload.LastName
				</MudText>

				<MudToolBar Dense="true" WrapContent="true" DisableGutters="true">
					<MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.Message" OnClick="ShowMessagesClick">
						پیامها
					</MudButton>

					<MudButton Color="Color.Success" StartIcon="@Icons.Filled.Logout" Variant="Variant.Outlined" Size="Size.Small" Href="/LoginPage/Logout">
						خروج
					</MudButton>

				</MudToolBar>


			</Authorized>
			<NotAuthorized>

				@*<MudButton Color="Color.Success" StartIcon="@Icons.Filled.Login" Variant="Variant.Text" Href="/LoginPage">
				Login
				</MudButton>*@

			</NotAuthorized>
		</AuthorizeView>

	</MudAppBar>
	
	<MudDrawer @bind-Open="@_drawerOpen" ClipMode="DrawerClipMode.Docked">
		<NavMenu />
	</MudDrawer>

	<MudDrawer @bind-Open="@_messageDrawerOpen" Anchor="Anchor.Right" MiniWidth="450" ClipMode="DrawerClipMode.Docked">
		<MudStack Row="false" Spacing="1">
			<MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Warning" Size="Size.Small" OnClick="CloseMessageDrawerClick"></MudIconButton>
		</MudStack>
		<CascadingValue Value="this">
			<IncommingMessageListComponent />
		</CascadingValue>


	</MudDrawer>
	<MudMainContent>
		<MudContainer MaxWidth="MaxWidth.ExtraLarge">
			@Body
		</MudContainer>
	</MudMainContent>


</MudLayout>


@code {

	// [Inject] UserSessionService UserSession { get; set; }
	//
	// [Inject] DataProviderService DataProvider { get; set; }
	//
	[Inject] AuthenticationStateProvider AuthenticationStateProvider { get; set; }
	//
	// [Inject] public IJSRuntime JsRuntime { get; set; }


	bool _drawerOpen = true;
	bool _messageDrawerOpen = false;

	private MudTheme _currentTheme;


	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			// await JsRuntime.InitializeMudBlazorExtensionsAsync();
			var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
			StateHasChanged();
		}
		await base.OnAfterRenderAsync(firstRender);
	}


	void DrawerToggle()
	{
		_drawerOpen = !_drawerOpen;
	}

	private void ShowMessagesClick()
	{
		_messageDrawerOpen = true;
	}

	private void CloseMessageDrawerClick()
	{
		_messageDrawerOpen = false;
	}

	public async Task ShowMessagesDrawer()
	{
		_messageDrawerOpen = true;
		await InvokeAsync(StateHasChanged);
	}

	public async Task DoStateHasChanged()
	{
		await InvokeAsync(StateHasChanged);
		
	}

}
