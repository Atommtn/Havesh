@using HaveshApp.Pages.MessageBox
@inherits LayoutComponentBase



<PageTitle>Havesh App</PageTitle>

<MudRTLProvider RightToLeft="true">

	<MudThemeProvider IsDarkMode="_isDark" />
	<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Medium" />
	<MudSnackbarProvider />

	<HubConnectorComponent />

	<MudLayout>
		<MudAppBar Fixed="true" Elevation="1">
			<MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
			HAVESH Portal
			<MudSpacer />
			<AuthorizeView>
				<Authorized>
					<MudMenu FullWidth="true" Size="Size.Large" StartIcon="@Icons.Material.Filled.Person2" Style="width: 250px;direction: rtl">
						<ActivatorContent>
							<MudChip Size="Size.Large">
								<MudAvatar Size="Size.Large" Variant="Variant.Filled" Class="mr-8" Elevation="1" Color="Color.Info">
									@_userSession.Payload?.FirstName?[0]
								</MudAvatar>
								@_userSession.Payload?.FirstName @_userSession.Payload?.LastName
							</MudChip>
						</ActivatorContent>
						<ChildContent>
							<MudMenuItem>
								سلام @_userSession.Payload.Gender @_userSession.Payload.FirstName @_userSession.Payload.LastName
							</MudMenuItem>
							<MudMenuItem OnClick="ShowMessagesClick">
								<MudChip Icon="@Icons.Material.Filled.Message">
									پیامها
								</MudChip>
							</MudMenuItem>
									<MudMenuItem Href="/Settings">
										تنظیمات
									</MudMenuItem>
							<MudMenuItem Href="/LoginPage/Logout">
								خروج
							</MudMenuItem>
						</ChildContent>
					</MudMenu>

				</Authorized>
				<NotAuthorized>

					@*<MudButton Color="Color.Success" StartIcon="@Icons.Material.Filled.Login" Variant="Variant.Text" Href="/LoginPage">
					Login
					</MudButton>*@

				</NotAuthorized>
			</AuthorizeView>
			<MudIconButton Icon="@Icons.Material.Filled.DarkMode" Color="Color.Surface" Variant="Variant.Filled" OnClick="()=> _isDark = !_isDark" />

		</MudAppBar>

		<MudDrawer @bind-Open="@_drawerOpen" ClipMode="DrawerClipMode.Docked">
			<NavMenu />
		</MudDrawer>

		<MudDrawer @bind-Open="@_messageDrawerOpen" Anchor="Anchor.Right" MiniWidth="500" ClipMode="DrawerClipMode.Docked">
			<MudStack Row="true" Spacing="1">
				<MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Warning" Size="Size.Medium" Class="m-1" OnClick="CloseMessageDrawerClick"></MudIconButton>
				<MudSpacer />
			</MudStack>
			<CascadingValue Value="this">
				<IncommingMessageListComponent />
			</CascadingValue>


		</MudDrawer>
		<MudMainContent>
			<MudContainer MaxWidth="MaxWidth.ExtraLarge">
				@Body
			</MudContainer>
		</MudMainContent>


	</MudLayout>
</MudRTLProvider>

@code {

	[Inject] AuthenticationStateProvider AuthenticationStateProvider { get; set; }


	bool _drawerOpen = true;
	bool _messageDrawerOpen = false;

	private MudTheme _currentTheme;


	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			// await JsRuntime.InitializeMudBlazorExtensionsAsync();
			var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
			StateHasChanged();
		}
		await base.OnAfterRenderAsync(firstRender);
	}


	void DrawerToggle()
	{
		_drawerOpen = !_drawerOpen;
	}

	private void ShowMessagesClick()
	{
		_messageDrawerOpen = true;
	}

	private void CloseMessageDrawerClick()
	{
		_messageDrawerOpen = false;
	}

	public async Task ShowMessagesDrawer()
	{
		_messageDrawerOpen = true;
		await InvokeAsync(StateHasChanged);
	}

	public async Task DoStateHasChanged()
	{
		await InvokeAsync(StateHasChanged);

	}

	private bool _isDark = true;
}
