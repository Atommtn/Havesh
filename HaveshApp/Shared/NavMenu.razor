@using Havesh.Model.Data.Dashboard
<MudNavMenu>
    @if (_userDashboardMenuItems is { })
    {
        @foreach (var dic in _userDashboardMenuItems)
        {
            <MudNavGroup Title="@dic.Item1" Expanded="false" Icon="@Icons.Material.Filled.Dashboard">
                @foreach (var dashboardT in dic.Item2)
                {
                    <MudNavLink Href="@($"/Dashboard/{dashboardT.Id}")" Match="NavLinkMatch.All">@dashboardT.Name</MudNavLink>
                }
            </MudNavGroup>
        }
    }
    <AuthorizeView Roles="Admin">
        <Authorized>
            @*<MudNavLink Href="/" Match="NavLinkMatch.All">Students Menu</MudNavLink>
            <MudNavLink Href="/Home" Match="NavLinkMatch.All">Home</MudNavLink>*@
            <MudNavLink Href="/" Match="NavLinkMatch.All">Havesh Home Page</MudNavLink>
            <MudNavGroup Title="Admin" Expanded="true" Icon="@Icons.Material.Filled.Dashboard">
                <MudNavLink Href="/DailyJV" Match="NavLinkMatch.Prefix">Daily JV</MudNavLink>
                <MudNavLink Href="/DailyJVChart" Match="NavLinkMatch.Prefix">Daily JV Chart</MudNavLink>
                <MudNavLink Href="/NewStudentChart" Match="NavLinkMatch.Prefix">New Student Chart</MudNavLink>
                <MudNavLink Href="/TeacherScheduler" Match="NavLinkMatch.Prefix">Teacher Scheduler</MudNavLink>
                <MudNavLink Href="/TimeTableAdmin" Match="NavLinkMatch.Prefix">TimeTable Admin Report</MudNavLink>
                <MudNavLink Href="/AdminSmsPanel" Match="NavLinkMatch.Prefix">Admin SMS Panel</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Setting" Icon="@Icons.Material.Filled.Settings">
                <MudNavLink Href="/BasicSetting" Match="NavLinkMatch.Prefix">Basic Setting</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Data Import" Icon="@Icons.Material.Filled.CopyAll">
                <MudNavLink Href="/BookPriceClone" Match="NavLinkMatch.Prefix">Clone BookPrice</MudNavLink>
                <MudNavLink Href="/ClonePage" Match="NavLinkMatch.Prefix">Clone TERM</MudNavLink>

            </MudNavGroup>
            <MudNavGroup Title="Definition" Icon="@Icons.Material.Filled.AddModerator">

                <MudNavLink Href="/ManageDaboards" Match="NavLinkMatch.Prefix">Dashboard Definition</MudNavLink>
                <MudDivider />
                <MudNavGroup Title="Term-Day" Icon="@Icons.Material.Filled.ViewDay">
                    <MudNavLink Href="/TermDefinition" Match="NavLinkMatch.Prefix">Term Definition</MudNavLink>
                    <MudNavLink Href="/IntervalDefinition" Match="NavLinkMatch.Prefix">Interval Definition</MudNavLink>
                    <MudNavLink Href="/DaySesseionDefinition" Match="NavLinkMatch.Prefix">DaySession Definition</MudNavLink>
                    <MudNavLink Href="/ScheduleDefinition" Match="NavLinkMatch.Prefix">Schedule Definition</MudNavLink>
                </MudNavGroup>
                <MudNavGroup Title="Level-Teacher-Class" Icon="@Icons.Material.Filled.CastForEducation">
                    <MudNavLink Href="/TeacherDefinition" Match="NavLinkMatch.Prefix">Teacher Definition</MudNavLink>
                    <MudNavLink Href="/ClassRoomDefinition" Match="NavLinkMatch.Prefix">ClassRoom Definition</MudNavLink>
                    <MudNavLink Href="/LevelPriceDefinition" Match="NavLinkMatch.Prefix">Level Price Definition</MudNavLink>
                </MudNavGroup>

                <MudNavLink Href="/LessonPlanDefinition" Match="NavLinkMatch.Prefix">Lesson Plan Definition</MudNavLink>

                <MudNavGroup Title="Sessions" Icon="@Icons.Material.Filled.MeetingRoom">
                    <MudNavLink Href="/TermSessionTemplate" Match="NavLinkMatch.Prefix">Term Session Template Definition</MudNavLink>
                    <MudNavLink Href="/SessionActiviy" Match="NavLinkMatch.Prefix">Session Activity</MudNavLink>
                    <MudNavLink Href="/ClassProgram/SessionGenerator" Match="NavLinkMatch.Prefix">Term Session Generator</MudNavLink>
                    <MudNavLink Href="/ClassProgram/SessionCancel" Match="NavLinkMatch.Prefix">Term Session Cancelation</MudNavLink>
                </MudNavGroup>
                <MudNavGroup Title="Membership" Icon="@Icons.Material.Filled.CardMembership">
                    <MudNavLink Href="/Users" Match="NavLinkMatch.Prefix">Users Definition</MudNavLink>
                    <MudNavLink Href="/Roles" Match="NavLinkMatch.Prefix">Roles Definition</MudNavLink>
                    <MudNavLink Href="/Permissions" Match="NavLinkMatch.Prefix">Permission Definition</MudNavLink>
                </MudNavGroup>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Roles="Admin,Modiator,Supervisor">
        <Authorized>


            <MudNavGroup Title="Dashboard" Expanded="true">
                <MudNavLink Href="/ClassProgram" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PersonalVideo" IconColor="Color.Warning">جدول برنامه کلاس ها</MudNavLink>
                <MudNavLink Href="/TeacherTimeTable" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PersonPin" IconColor="Color.Error">برنامه کلاس معلمین</MudNavLink>
                <MudDivider></MudDivider>
                <MudNavLink Href="/DailyJV" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Today" IconColor="Color.Info">ثبت روزانه</MudNavLink>
                <MudNavLink Href="/StudentJVReport" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Money" IconColor="Color.Info">گزارش بدهی</MudNavLink>
                @*<MudNavLink Href="/siteJvPage" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.RecordVoiceOver">ثبت واریز اولیا</MudNavLink>*@
                <MudNavLink Href="/prereg" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.RecordVoiceOver">پیش ثبت نام</MudNavLink>
                <MudDivider></MudDivider>
                <MudNavLink Href="/StudentSearch" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PersonSearch" IconColor="Color.Success">زبان آموزان</MudNavLink>
                <MudNavLink Href="/FollowUp" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.FollowTheSigns" IconColor="Color.Warning">پیگیری</MudNavLink>
                <MudNavLink Href="/Logs" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Details" IconColor="Color.Warning">سابقه فعالیت</MudNavLink>
                <MudNavLink Href="/Profile" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.BookOnline">پروفایهای آنلاین</MudNavLink>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Roles="Supervisor">
        <Authorized>
            <MudText Typo="Typo.caption" Color="Color.Info" GutterBottom="true">
                Supervisor Menu
            </MudText>

            <MudNavGroup Title="Definition" Icon="@Icons.Material.Filled.AddModerator">


                <MudNavLink Href="/TeacherDefinition" Match="NavLinkMatch.Prefix">Teacher Definition</MudNavLink>
                <MudNavLink Href="/LessonPlanDefinition" Match="NavLinkMatch.Prefix">Lesson Plan Definition</MudNavLink>
                <MudDivider />
                <MudNavLink Href="/LevelPriceDefinition" Match="NavLinkMatch.Prefix">Level Price Definition</MudNavLink>
                <MudDivider />
                <MudNavLink Href="/IntervalDefinition" Match="NavLinkMatch.Prefix">Interval Definition</MudNavLink>
                <MudNavLink Href="/DaySesseionDefinition" Match="NavLinkMatch.Prefix">DaySession Definition</MudNavLink>
                <MudNavLink Href="/ScheduleDefinition" Match="NavLinkMatch.Prefix">Schedule Definition</MudNavLink>

                <MudNavGroup Title="Sessions" Icon="@Icons.Material.Filled.MeetingRoom">
                    <MudNavLink Href="/TermSessionTemplate" Match="NavLinkMatch.Prefix">Term Session Template Definition</MudNavLink>
                    <MudNavLink Href="/SessionActiviy" Match="NavLinkMatch.Prefix">Session Activity</MudNavLink>
                    <MudNavLink Href="/ClassProgram/SessionGenerator" Match="NavLinkMatch.Prefix">Term Session Generator</MudNavLink>
                    <MudNavLink Href="/ClassProgram/SessionCancel" Match="NavLinkMatch.Prefix">Term Session Cancelation</MudNavLink>
                </MudNavGroup>

            </MudNavGroup>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Roles="Teacher">
        <Authorized>
            <MudNavLink Href="/TeacherScheduler/" Match="NavLinkMatch.Prefix">Teacher Scheduler</MudNavLink>
        </Authorized>
    </AuthorizeView>

</MudNavMenu>

@code
{
    List<(string, List<DashboardTemplate>)>? _userDashboardMenuItems = new();
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _userDashboardMenuItems = _dashboardProvider.GetUserDashboardMenuItems(_userSession.User);
            StateHasChanged();
        }
        base.OnAfterRender(firstRender);
    }
}
