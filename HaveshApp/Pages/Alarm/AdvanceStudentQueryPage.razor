@page "/AdvanceRegistration"
@using Havesh.Model.Model

<MudStack Row="true" Spacing="1">
	<MudButton Variant="Variant.Text" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Close" OnClick="RegisterAdvanceStudentClick">
		ثبت نام زبان آموز
	</MudButton>

</MudStack>


@code {

	[Inject] public UserSessionService SessionService { get; set; }

	private void RegisterAdvanceStudentClick()
	{
		const string filterCode = "0011";
		var advanceRegistration = new AdvanceRegistration()
		{
			Title = "Do Action",
			DateTime = DateTime.Now,
			Allow = true,
			UserName = SessionService.UserName!,
			BranchFk = SessionService.User!.BranchFk,
			Code = filterCode
		};
		_dataProvider.RegisterAdvanceUser(advanceRegistration);
	}

}
