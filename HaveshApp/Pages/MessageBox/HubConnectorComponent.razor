@using Microsoft.AspNetCore.SignalR.Client
@using HaveshApp.Classes;
@using HaveshApp.Classes.ExtensionMethods
@using Microsoft.AspNetCore.SignalR.Client
@using HaveshApp.Classes.ExtensionMethods
@implements IAsyncDisposable

@code {
	private HubConnection? hubConnection;
	[Inject] NavigationManager Navigation { get; set; }
	[Inject] UserSessionService UserSessionService { get; set; }
	[Inject] MessageHandlingService MessageHandlingService { get; set; }

	protected override async Task OnInitializedAsync()
	{
		var userId = UserSessionService.User?.Id ?? 0;
		var absoluteUri = Navigation.ToAbsoluteUri($"/apphub?UserId={userId}");
		Console.WriteLine(" ========== Hub URL ========== ");
		Console.WriteLine(" ==================== " + absoluteUri);
		Console.WriteLine(" ==================== ");
		hubConnection = new HubConnectionBuilder()
			.WithUrl(absoluteUri, options =>
			{
				options.WebSocketConfiguration = conf =>
				{
					conf.RemoteCertificateValidationCallback = (message, cert, chain, errors) => true;
				};
				options.HttpMessageHandlerFactory = factory => new HttpClientHandler
					{
						ServerCertificateCustomValidationCallback = (message, cert, chain, errors) => true
					};
				//options.AccessTokenProvider = () => Task.FromResult(Token);
			})
			.Build();

		hubConnection.On<MessageDto>("HandleIncomingMessage", (message) =>
		{
			MessageHandlingService.HandleIncomingMessage(message);
		});


		try
		{
			await hubConnection.StartAsync();

			Console.WriteLine($" @@@@@@@@@@@");
			Console.WriteLine($" @@@@@@@@@@@ Connected : {hubConnection.ConnectionId}");
			Console.WriteLine($" @@@@@@@@@@@");

		}
		catch (Exception e)
		{
			Console.WriteLine(new string('=', 80));
			Console.WriteLine(new string('=', 80));
			Console.WriteLine(e);
			Console.WriteLine(new string('=', 80));
			Console.WriteLine(new string('=', 80));
		}
	}

	public async ValueTask DisposeAsync()
	{

		if (hubConnection != null)
		{
			Console.WriteLine($" *******");
			Console.WriteLine($" ******* DISPOSED : {hubConnection.ConnectionId}");
			Console.WriteLine($" *******");
			await hubConnection.DisposeAsync();
		}

	}
}
