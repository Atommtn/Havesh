@using ShokouhApp.Services
@using ShokouhApp.Model

<InputFile id="@("x"+_controlGuid.ToString("N"))" OnChange="UploadFiles" hidden />

<MudCard>
    <MudCardContent>
        <MudStack Row="false" AlignItems="AlignItems.Center" Justify="Justify.Center">
            @if (Attachment is { DataUrl: { } })
            {
                if (Attachment.ContentType.StartsWith("image"))
                {
                    <MudImage Src="@Attachment.DataUrl" Style="width:100%;" ObjectPosition="ObjectPosition.Center" ObjectFit="ObjectFit.Contain"></MudImage>
                }
                else if (Attachment.ContentType.EndsWith("pdf"))
                {
                    <MudImage Src="@("/images/PdfFile.png")" Width="150" Height="150"></MudImage>
                }
                else
                {
                    <MudImage Src="@ContetnImageFile" Width="150" Height="150"></MudImage>
                }
            }
            else
            {
                <MudImage Src="@NoImageFile" Width="150" Height="150"></MudImage>
            }
            @if (_showPendingUpload)
            {
                <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
            }
            @if (Error.IsNotNullOrEmpty())
            {
                <MudText Class="ma-4" Typo="Typo.subtitle2" Color="Color.Error">
                    @Error
                </MudText>
            }
        </MudStack>
    </MudCardContent>
    <MudCardActions>
        @if (Attachment is { DataUrl: { } })
        {
            <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Error" EndIcon="@Icons.TwoTone.Delete" OnClick="RemovePictureClick">
                حذف تصویر
            </MudButton>
        }
        @if (!_showPendingUpload)
        {
            <MudButton Class="m-3 p-2"
                   HtmlTag="label"
                   for="@("x"+_controlGuid.ToString("N"))"
                   Color="Color.Info"
                   Size="Size.Large"
                   FullWidth="true"
                   StartIcon="@Icons.TwoTone.Upload"
                   Variant="Variant.Filled">
                @UploadButtonText
            </MudButton>
        }
        else
        {
            <MudText Typo="Typo.subtitle1" Color="Color.Warning">
                لطفا تا بارگیری کامل تصویر و مشاهده در جعبه بالا صبر کنید ...
            </MudText>

        }
    </MudCardActions>
</MudCard>
